<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="DefenderUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DefenderUI"
    xmlns:controls="using:DefenderUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DefenderUI"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Custom Title Bar                                             -->
        <!-- Logo + DefenderUI + StatusPill  |  spacer  |  Theme/Notif   -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid
            x:Name="AppTitleBarGrid"
            Grid.Row="0"
            Height="48"
            Padding="12,0"
            Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Logo + App Name -->
            <StackPanel
                Grid.Column="0"
                Orientation="Horizontal"
                Spacing="10"
                VerticalAlignment="Center"
                Margin="4,0,0,0">
                <Image
                    Source="ms-appx:///Assets/AppLogo-32.png"
                    Width="20"
                    Height="20"
                    VerticalAlignment="Center" />
                <TextBlock
                    Text="DefenderUI"
                    Style="{StaticResource TitleMediumTextStyle}"
                    VerticalAlignment="Center" />
            </StackPanel>

            <!-- Status Pill -->
            <controls:StatusPill
                x:Name="HeaderStatusPill"
                Grid.Column="1"
                Severity="Protected"
                Text="Protected"
                Margin="16,0,0,0"
                VerticalAlignment="Center" />

            <!-- Spacer (draggable region, set via code-behind) -->
            <Border
                x:Name="TitleBarDragRegion"
                Grid.Column="2"
                Background="Transparent" />

            <!-- Right: Theme toggle + Notifications -->
            <StackPanel
                Grid.Column="3"
                Orientation="Horizontal"
                Spacing="4"
                VerticalAlignment="Center"
                Margin="0,0,4,0">
                <Button
                    x:Name="ThemeToggleButton"
                    Style="{StaticResource IconButtonStyle}"
                    Click="ThemeToggleButton_Click"
                    ToolTipService.ToolTip="Toggle theme"
                    AutomationProperties.Name="Toggle theme">
                    <FontIcon
                        x:Name="ThemeToggleIcon"
                        Glyph="&#xE706;"
                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                        FontSize="16" />
                </Button>
                <Button
                    x:Name="NotificationsButton"
                    Style="{StaticResource IconButtonStyle}"
                    ToolTipService.ToolTip="Notifications"
                    AutomationProperties.Name="Notifications">
                    <FontIcon
                        Glyph="&#xEA8F;"
                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                        FontSize="16" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Shell: NavigationView + Content Frame                        -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="True"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            OpenPaneLength="280"
            CompactPaneLength="72"
            Background="Transparent"
            Loaded="NavView_Loaded"
            SelectionChanged="NavView_SelectionChanged"
            AutomationProperties.Name="Main navigation">

            <!-- Menu Items -->
            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="Dashboard"
                    Tag="dashboard"
                    IsSelected="True"
                    AutomationProperties.Name="Dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon
                            Glyph="&#xE80F;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Scan"
                    Tag="scan"
                    AutomationProperties.Name="Scan">
                    <NavigationViewItem.Icon>
                        <FontIcon
                            Glyph="&#xE773;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Protection"
                    Tag="protection"
                    AutomationProperties.Name="Protection">
                    <NavigationViewItem.Icon>
                        <FontIcon
                            Glyph="&#xE72E;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Quarantine"
                    Tag="quarantine"
                    AutomationProperties.Name="Quarantine">
                    <NavigationViewItem.Icon>
                        <FontIcon
                            Glyph="&#xE7B8;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Reports"
                    Tag="reports"
                    AutomationProperties.Name="Reports">
                    <NavigationViewItem.Icon>
                        <FontIcon
                            Glyph="&#xE9D2;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Update"
                    Tag="update"
                    AutomationProperties.Name="Update">
                    <NavigationViewItem.Icon>
                        <FontIcon
                            Glyph="&#xE895;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- Footer Items -->
            <NavigationView.FooterMenuItems>
                <NavigationViewItem
                    Content="Settings"
                    Tag="settings"
                    AutomationProperties.Name="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon
                            Glyph="&#xE713;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <!-- Content Frame -->
            <Frame
                x:Name="ContentFrame"
                Padding="0"
                Background="Transparent" />
        </NavigationView>
    </Grid>
</Window>
