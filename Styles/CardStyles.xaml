<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:DefenderUI.Helpers">

    <!--
        ═══════════════════════════════════════════════════════════════════
        DefenderUI — Card Styles (Faz 1)
        ═══════════════════════════════════════════════════════════════════
        Yeni stiller:
            • SurfaceCardStyle       — Surface kartı + ElevationLow
            • InteractiveCardStyle   — hover → SurfaceCardHover + ElevationMedium
            • HeroStatusCardStyle    — Büyük padding + ElevationMedium + Hero radius
            • StatCardStyle          — Kompakt KPI kartı
            • FeatureTileCardStyle   — InteractiveCard + min height 140

        Geriye dönük uyumluluk:
            DashboardCardStyle, KpiCardStyle, HeroCardStyle, ActionCardStyle,
            AlertCardStyle, DangerAlertCardStyle, SuccessAlertCardStyle
        ═══════════════════════════════════════════════════════════════════
    -->

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- SurfaceCardStyle (base)                                      -->
    <!-- NOT: ThemeShadow ve Translation setter'ları WinUI 3 XAML     -->
    <!-- compiler tarafında Style içinde problemli olabildiği için    -->
    <!-- "flat" bir tabandan başlıyoruz. Gölge isteyen kart çağıran   -->
    <!-- tarafta (örn. <Border.Shadow>) opt-in olarak ekleyebilir.    -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="SurfaceCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SurfaceCardBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusCard}" />
        <Setter Property="Padding" Value="{StaticResource PaddingCardDefault}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- InteractiveCardStyle (hover: lift + brighter surface)        -->
    <!-- Hover efekti helpers:CardHoverEffect attached property'si    -->
    <!-- ile sağlanır (projede zaten mevcut).                         -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="InteractiveCardStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardStyle}">
        <Setter Property="helpers:CardHoverEffect.IsEnabled" Value="True" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- HeroStatusCardStyle                                          -->
    <!-- Büyük, dikkat çekici durum kartı (dashboard hero)            -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="HeroStatusCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SurfaceElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusHero}" />
        <Setter Property="Padding" Value="{StaticResource Thickness2xl}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- StatCardStyle                                                -->
    <!-- Kompakt KPI kartı — başlık + büyük sayı + ikon              -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="StatCardStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardStyle}">
        <Setter Property="Padding" Value="{StaticResource ThicknessLg}" />
        <Setter Property="MinWidth" Value="160" />
        <Setter Property="MinHeight" Value="96" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- FeatureTileCardStyle                                         -->
    <!-- Kaspersky tarzı feature grid tile (hover + min height)       -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="FeatureTileCardStyle" TargetType="Border" BasedOn="{StaticResource InteractiveCardStyle}">
        <Setter Property="MinHeight" Value="140" />
        <Setter Property="Padding" Value="{StaticResource ThicknessXl}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Alert Card Variants                                          -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="AlertCardWarningStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource StatusWarningSoftBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource StatusWarningBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusCard}" />
        <Setter Property="Padding" Value="{StaticResource PaddingCardDefault}" />
    </Style>

    <Style x:Key="AlertCardDangerStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource StatusRiskSoftBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource StatusRiskBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusCard}" />
        <Setter Property="Padding" Value="{StaticResource PaddingCardDefault}" />
    </Style>

    <Style x:Key="AlertCardSuccessStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource StatusProtectedSoftBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource StatusProtectedBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusCard}" />
        <Setter Property="Padding" Value="{StaticResource PaddingCardDefault}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- LEGACY ALIASES (mevcut View'lerin kırılmaması için)          -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="DashboardCardStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardStyle}">
        <Setter Property="Padding" Value="20" />
        <Setter Property="helpers:CardHoverEffect.IsEnabled" Value="True" />
    </Style>

    <Style x:Key="KpiCardStyle" TargetType="Border" BasedOn="{StaticResource StatCardStyle}">
        <Setter Property="helpers:CardHoverEffect.IsEnabled" Value="True" />
    </Style>

    <Style x:Key="HeroCardStyle" TargetType="Border" BasedOn="{StaticResource HeroStatusCardStyle}" />

    <Style x:Key="ActionCardStyle" TargetType="Border" BasedOn="{StaticResource InteractiveCardStyle}">
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="AlertCardStyle" TargetType="Border" BasedOn="{StaticResource AlertCardWarningStyle}" />
    <Style x:Key="DangerAlertCardStyle" TargetType="Border" BasedOn="{StaticResource AlertCardDangerStyle}" />
    <Style x:Key="SuccessAlertCardStyle" TargetType="Border" BasedOn="{StaticResource AlertCardSuccessStyle}" />

</ResourceDictionary>