<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:DefenderUI.Helpers">

    <!--
        ═══════════════════════════════════════════════════════════════════
        DefenderUI — Button Styles (Faz 1)
        ═══════════════════════════════════════════════════════════════════
        Hepsi BasedOn="{StaticResource DefaultButtonStyle}" üzerine kuruludur.

        NOT: WinUI 3'te ButtonStyle içinde <Style.Resources> üzerinden
        ButtonBackground / ButtonBackgroundPointerOver vb. key override'ı
        ileri sürümlerde XAML compiler hatalarına yol açabildiği için,
        burada basit Setter tabanlı görsel tanım tercih edilmiştir.
        PointerOver / Pressed / Disabled durumları için varsayılan WinUI
        davranışı (opacity azalması) yeterli kabul edilmiştir; görsel
        ince ayar Faz 2'de özel ControlTemplate ile yapılacaktır.
        ═══════════════════════════════════════════════════════════════════
    -->

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Primary Action Button (accent-filled CTA)                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="{ThemeResource AccentPrimaryBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource TextOnAccentBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AccentPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusButton}" />
        <Setter Property="Padding" Value="{StaticResource PaddingButtonDefault}" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="helpers:ButtonEffects.EnableMicroInteractions" Value="True" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Secondary Action Button (outlined)                           -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource BorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusButton}" />
        <Setter Property="Padding" Value="{StaticResource PaddingButtonDefault}" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="helpers:ButtonEffects.EnableMicroInteractions" Value="True" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Subtle Button (transparent, minimal)                         -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="SubtleButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusButton}" />
        <Setter Property="Padding" Value="{StaticResource PaddingButtonDefault}" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="helpers:ButtonEffects.EnableMicroInteractions" Value="True" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Danger Button (destructive action)                           -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="{ThemeResource StatusRiskBrush}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="{ThemeResource StatusRiskBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusButton}" />
        <Setter Property="Padding" Value="{StaticResource PaddingButtonDefault}" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="helpers:ButtonEffects.EnableMicroInteractions" Value="True" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Icon Button (square 40x40, FontIcon content)                 -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusButton}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="helpers:ButtonEffects.EnableMicroInteractions" Value="True" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Pill Button (fully-rounded accent)                           -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="PillButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}">
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusPill}" />
        <Setter Property="Padding" Value="{StaticResource PaddingButtonPill}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- LEGACY ALIASES                                               -->
    <!-- Eski X:Key referanslarını (PrimaryButtonStyle, SecondaryButtonStyle,
         AccentButtonStyle) koruyan geri uyumluluk tanımları.         -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}" />
    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}" />
    <!-- DashboardPage.xaml'de referanslanıyordu ama tanımsızdı (runtime kırılma riski). -->
    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryActionButtonStyle}" />

</ResourceDictionary>