<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ═══════════════════════════════════════════════════════════════════
        DefenderUI — Spacing Tokens (Faz 1)
        ═══════════════════════════════════════════════════════════════════
        8px grid tabanlı numerik (double) ve hazır Thickness kaynakları.
        Stack/Grid Spacing binding gerektirdiği yerlerde x:Double,
        Margin/Padding içinse Thickness varyantları kullanılır.
        ═══════════════════════════════════════════════════════════════════
    -->

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Numeric Spacing Tokens (double)                              -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <x:Double x:Key="SpaceXs">4</x:Double>
    <x:Double x:Key="SpaceSm">8</x:Double>
    <x:Double x:Key="SpaceMd">12</x:Double>
    <x:Double x:Key="SpaceLg">16</x:Double>
    <x:Double x:Key="SpaceXl">24</x:Double>
    <x:Double x:Key="Space2xl">32</x:Double>
    <x:Double x:Key="Space3xl">48</x:Double>
    <x:Double x:Key="Space4xl">64</x:Double>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Thickness Tokens (Margin / Padding)                          -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Thickness x:Key="ThicknessXs">4</Thickness>
    <Thickness x:Key="ThicknessSm">8</Thickness>
    <Thickness x:Key="ThicknessMd">12</Thickness>
    <Thickness x:Key="ThicknessLg">16</Thickness>
    <Thickness x:Key="ThicknessXl">24</Thickness>
    <Thickness x:Key="Thickness2xl">32</Thickness>
    <Thickness x:Key="Thickness3xl">48</Thickness>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Semantic Thickness Tokens                                    -->
    <!-- Yaygın kullanım alanları için hazır Padding / Margin değerleri -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- Card iç padding (default): 16px her yön -->
    <Thickness x:Key="PaddingCardDefault">16</Thickness>

    <!-- Page padding (sayfa dış kenar): 24px her yön -->
    <Thickness x:Key="PaddingPage">24</Thickness>

    <!-- Row/Item iç padding: dikey 12 / yatay 16 -->
    <Thickness x:Key="PaddingRowDefault">16,12</Thickness>

    <!-- Button default padding: yatay 16 / dikey 10 -->
    <Thickness x:Key="PaddingButtonDefault">16,10</Thickness>

    <!-- Button kompakt padding: yatay 12 / dikey 6 -->
    <Thickness x:Key="PaddingButtonCompact">12,6</Thickness>

    <!-- Pill button padding: yatay 16 / dikey 8 -->
    <Thickness x:Key="PaddingButtonPill">16,8</Thickness>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Gap Tokens (StackPanel.Spacing / Grid.RowSpacing)            -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <x:Double x:Key="GapRowDefault">12</x:Double>
    <x:Double x:Key="GapColumnDefault">12</x:Double>
    <x:Double x:Key="GapCardInner">16</x:Double>
    <x:Double x:Key="GapSectionOuter">24</x:Double>
    <x:Double x:Key="GapTight">8</x:Double>
    <x:Double x:Key="GapLoose">32</x:Double>

</ResourceDictionary>