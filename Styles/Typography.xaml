<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ═══════════════════════════════════════════════════════════════════
        DefenderUI — Typography Scale (Faz 1)
        ═══════════════════════════════════════════════════════════════════
        Font:  Segoe UI Variable Display (fallback Segoe UI, sans-serif)
        Semantic token set:
            • DisplayLargeTextStyle   36px SemiBold  — hero başlıkları
            • DisplayMediumTextStyle  28px SemiBold
            • TitleLargeTextStyle     20px SemiBold
            • TitleMediumTextStyle    16px SemiBold
            • BodyLargeTextStyle      14px Normal
            • BodyMediumTextStyle     13px Normal
            • CaptionTextStyle        12px Normal (TextTertiary)
            • OverlineTextStyle       11px SemiBold, uppercase, letter-spacing 50
        Geriye dönük uyumluluk için eski isimler (TitleLargeStyle, TitleStyle,
        SubtitleStyle, BodyLargeStyle, BodyStyle, CaptionStyle, DisplayNumberStyle,
        HeroNumberStyle, BodySecondaryStyle, CaptionTertiaryStyle) ALIAS olarak
        korunur; mevcut View'ler kırılmaz.
        ═══════════════════════════════════════════════════════════════════
    -->

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Font Family                                                  -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <FontFamily x:Key="AppFontFamily">Segoe UI Variable Display, Segoe UI Variable, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="AppFontFamilyText">Segoe UI Variable Text, Segoe UI Variable, Segoe UI, sans-serif</FontFamily>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- NEW SEMANTIC TYPOGRAPHY TOKENS                               -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- Display (hero başlıkları) -->
    <Style x:Key="DisplayLargeTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="44" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="DisplayMediumTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="36" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!-- Title (section başlıkları) -->
    <Style x:Key="TitleLargeTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="28" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="TitleMediumTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="22" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!-- Body -->
    <Style x:Key="BodyLargeTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyText}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="BodyMediumTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyText}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="18" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Caption -->
    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyText}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="Foreground" Value="{ThemeResource TextTertiaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Overline (small uppercase label) -->
    <Style x:Key="OverlineTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyText}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="CharacterSpacing" Value="50" />
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <!--
            NOTE: WinUI TextBlock does not have a built-in 'TextTransform: uppercase'
            property. Callers should provide already-uppercase text
            (e.g. Text="OVERVIEW"). CharacterSpacing 50 = ~50/1000em tracking.
        -->
    </Style>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- LEGACY ALIASES (geriye dönük uyumluluk)                      -->
    <!-- Mevcut View/XAML'lerdeki eski Style x:Key referansları       -->
    <!-- kırılmasın diye aynı semantikle yeniden isimlendirilmiştir.  -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <Style x:Key="TitleLargeStyle" TargetType="TextBlock" BasedOn="{StaticResource DisplayMediumTextStyle}" />
    <Style x:Key="TitleStyle" TargetType="TextBlock" BasedOn="{StaticResource DisplayMediumTextStyle}">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="LineHeight" Value="32" />
    </Style>
    <Style x:Key="SubtitleStyle" TargetType="TextBlock" BasedOn="{StaticResource TitleLargeTextStyle}" />

    <Style x:Key="BodyLargeStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyLargeTextStyle}">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="LineHeight" Value="22" />
    </Style>
    <Style x:Key="BodyStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyLargeTextStyle}" />
    <Style x:Key="CaptionStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
        <!-- Legacy CaptionStyle used TextSecondary; we keep that for compatibility -->
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
    </Style>

    <!-- Display number / hero number (KPI cards) -->
    <Style x:Key="DisplayNumberStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="LineHeight" Value="44" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>

    <Style x:Key="HeroNumberStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="48" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="LineHeight" Value="56" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>

    <!-- Secondary / Tertiary variants -->
    <Style x:Key="BodySecondaryStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyLargeTextStyle}">
        <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="CaptionTertiaryStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
        <Setter Property="Foreground" Value="{ThemeResource TextTertiaryBrush}" />
    </Style>

</ResourceDictionary>