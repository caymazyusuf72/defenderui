<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ═══════════════════════════════════════════════════════════════════
        DefenderUI — Elevation / Shadow Tokens (Faz 1)
        ═══════════════════════════════════════════════════════════════════

        WINUI 3 NOTLARI:
        • ThemeShadow, sanal (Z) bir 3B gölge üretir; kullanım için Border'a
          doğrudan `<Border.Shadow><ThemeShadow/></Border.Shadow>` atanır
          ve Translation="0,0,N" ile Z-depth verilir. Bu ATTACH'lar kurucu
          tarafta yapılmalıdır — `Style` setter'ı olarak doğrudan atanması
          tüm WinUI 3 runtime sürümlerinde güvenilir değildir.
        • Bu nedenle bu dosya; her elevation seviyesi için (a) paylaşılan
          Z-Depth token'ları, (b) "flat" görsel stiller, (c) opsiyonel bir
          `ThemeShadow` kaynağı sunar. Gölgeyi eklemek isteyen kart çağıranın
          sorumluluğundadır:

            <Border Style="{StaticResource ElevationMedium}"
                    Translation="0,0,16">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                ...
            </Border>

        FALLBACK:
        Mica/Acrylic backdrop'larda gölge etkisi hafif olur; güvenli varsayılan
        olarak ince BorderBrush + ince BorderThickness ile hiyerarşi yaratılır.
        ═══════════════════════════════════════════════════════════════════
    -->

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Shared ThemeShadow (opt-in)                                 -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <ThemeShadow x:Key="AppThemeShadow" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Z-Depth tokens (double) — Translation.Z için                 -->
    <!-- Kullanım: Translation="0,0,{StaticResource ElevationDepthLow}" -->
    <!-- (XAML Translation için Vector3 string literal; aşağıdaki     -->
    <!-- token'lar doc amaçlıdır ve çağıran tarafında literal olarak  -->
    <!-- kullanılır: Translation="0,0,4")                             -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <x:Double x:Key="ElevationDepthLow">4</x:Double>
    <x:Double x:Key="ElevationDepthMedium">16</x:Double>
    <x:Double x:Key="ElevationDepthHigh">32</x:Double>
    <x:Double x:Key="ElevationDepthFloating">64</x:Double>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Elevation Styles (TargetType="Border") — FLAT tabanlı        -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- Low (resting cards) — 1px subtle border, minimal kontrast -->
    <Style x:Key="ElevationLow" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SurfaceCardBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusCard}" />
    </Style>

    <!-- Medium (hover / interactive) — biraz daha belirgin kenarlık -->
    <Style x:Key="ElevationMedium" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SurfaceCardBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource BorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusCard}" />
    </Style>

    <!-- High (prominent hero card, popovers) -->
    <Style x:Key="ElevationHigh" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SurfaceElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusHero}" />
    </Style>

    <!-- Floating (modal / toast / flyout) -->
    <Style x:Key="ElevationFloating" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SurfaceElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusLg}" />
    </Style>

    <!-- Flat alias (explicit flat variants kept for clarity) -->
    <Style x:Key="ElevationLowFlat" TargetType="Border" BasedOn="{StaticResource ElevationLow}" />
    <Style x:Key="ElevationMediumFlat" TargetType="Border" BasedOn="{StaticResource ElevationMedium}" />

</ResourceDictionary>