<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ═══════════════════════════════════════════════════════════════════
        DefenderUI — Corner Radius Tokens (Faz 1)
        ═══════════════════════════════════════════════════════════════════
        Numerik radius değerleri (double) ve yaygın kullanım için hazır
        CornerRadius kaynakları.
        ═══════════════════════════════════════════════════════════════════
    -->

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Numeric Radius Tokens (double)                               -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <x:Double x:Key="RadiusSm">4</x:Double>
    <x:Double x:Key="RadiusMd">8</x:Double>
    <x:Double x:Key="RadiusLg">12</x:Double>
    <x:Double x:Key="RadiusXl">16</x:Double>
    <x:Double x:Key="RadiusPill">9999</x:Double>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- CornerRadius Tokens (kullanıma hazır)                        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <CornerRadius x:Key="CornerRadiusSm">4</CornerRadius>
    <CornerRadius x:Key="CornerRadiusMd">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusLg">12</CornerRadius>
    <CornerRadius x:Key="CornerRadiusXl">16</CornerRadius>

    <!-- Semantic tokens -->
    <CornerRadius x:Key="CornerRadiusCard">12</CornerRadius>
    <CornerRadius x:Key="CornerRadiusButton">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusPill">9999</CornerRadius>
    <CornerRadius x:Key="CornerRadiusInput">6</CornerRadius>
    <CornerRadius x:Key="CornerRadiusHero">16</CornerRadius>

</ResourceDictionary>