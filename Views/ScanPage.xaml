<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DefenderUI.Views.ScanPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:DefenderUI.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:helpers="using:DefenderUI.Helpers"
    xmlns:models="using:DefenderUI.Models"
    xmlns:services="using:DefenderUI.Services"
    xmlns:local="using:DefenderUI.Views"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    Background="Transparent">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled">

        <Grid x:Name="RootContent" Padding="{StaticResource PaddingPage}">

            <!-- ════════════════════════════════════════════════════════ -->
            <!-- IDLE STATE — mod seçim + başlat                          -->
            <!-- ════════════════════════════════════════════════════════ -->
            <StackPanel
                x:Name="IdleStatePanel"
                Spacing="{StaticResource Space2xl}"
                Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">

                <!-- Header -->
                <StackPanel Spacing="4">
                    <TextBlock
                        Text="Virüs Taraması"
                        Style="{StaticResource DisplayMediumTextStyle}"
                        AutomationProperties.HeadingLevel="Level1" />
                    <TextBlock
                        Text="Sisteminizi tehditlere karşı tarayın"
                        Style="{StaticResource BodyLargeTextStyle}"
                        Foreground="{ThemeResource TextSecondaryBrush}" />
                </StackPanel>

                <!-- Mode grid -->
                <StackPanel Spacing="{StaticResource SpaceLg}">
                    <TextBlock
                        Text="Tarama Modu Seçin"
                        Style="{StaticResource TitleLargeTextStyle}"
                        AutomationProperties.HeadingLevel="Level2" />

                    <muxc:ItemsRepeater ItemsSource="{x:Bind ViewModel.ScanModes, Mode=OneWay}">
                        <muxc:ItemsRepeater.Layout>
                            <muxc:UniformGridLayout
                                MinItemWidth="240"
                                MinItemHeight="180"
                                MinColumnSpacing="16"
                                MinRowSpacing="16"
                                ItemsStretch="Fill" />
                        </muxc:ItemsRepeater.Layout>
                        <muxc:ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:ScanModeOption">
                                <controls:ScanModeCard
                                    Mode="{x:Bind Mode}"
                                    Glyph="{x:Bind Glyph}"
                                    Title="{x:Bind Title}"
                                    Description="{x:Bind Description}"
                                    EstimatedDuration="{x:Bind EstimatedDuration}"
                                    Command="{Binding ElementName=RootPage, Path=ViewModel.SelectModeCommand}" />
                            </DataTemplate>
                        </muxc:ItemsRepeater.ItemTemplate>
                    </muxc:ItemsRepeater>
                </StackPanel>

                <!-- Custom paths (sadece Custom modda) -->
                <Border
                    Style="{StaticResource SurfaceCardStyle}"
                    Visibility="{x:Bind ViewModel.IsCustomMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Spacing="{StaticResource SpaceMd}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock
                                    Text="Özel Yollar"
                                    Style="{StaticResource TitleMediumTextStyle}" />
                                <TextBlock
                                    Text="Taranacak klasörleri ekleyin."
                                    Style="{StaticResource CaptionTextStyle}" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                x:Name="AddPathButton"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Click="AddPathButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon
                                        Glyph="&#xE710;"
                                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                        FontSize="14" />
                                    <TextBlock Text="Klasör Ekle" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <ListView
                            ItemsSource="{x:Bind ViewModel.CustomPaths, Mode=OneWay}"
                            SelectionMode="None"
                            MaxHeight="200"
                            Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Grid ColumnSpacing="12" Padding="4,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            Grid.Column="0"
                                            Glyph="&#xE8B7;"
                                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                            FontSize="16"
                                            Foreground="{ThemeResource AccentPrimaryBrush}"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{x:Bind}"
                                            Style="{StaticResource BodyMediumTextStyle}"
                                            TextTrimming="CharacterEllipsis"
                                            VerticalAlignment="Center" />
                                        <Button
                                            Grid.Column="2"
                                            Style="{StaticResource IconButtonStyle}"
                                            Command="{Binding ElementName=RootPage, Path=ViewModel.RemoveCustomPathCommand}"
                                            CommandParameter="{x:Bind}"
                                            ToolTipService.ToolTip="Kaldır">
                                            <FontIcon
                                                Glyph="&#xE74D;"
                                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                FontSize="14" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock
                            Text="Henüz klasör eklenmedi."
                            Style="{StaticResource CaptionTextStyle}"
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextTertiaryBrush}"
                            Visibility="{x:Bind local:ScanPage.IsCollectionEmpty(ViewModel.CustomPaths.Count), Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <!-- Start button -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button
                        Grid.Column="1"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        MinWidth="200"
                        Command="{x:Bind ViewModel.StartScanCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon
                                Glyph="&#xE768;"
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                FontSize="14" />
                            <TextBlock Text="Taramayı Başlat" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Last completion summary -->
                <Border
                    Style="{StaticResource SurfaceCardStyle}"
                    Visibility="{x:Bind ViewModel.HasLastCompletion, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Spacing="{StaticResource SpaceMd}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon
                                Glyph="&#xE73E;"
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                FontSize="20"
                                Foreground="{ThemeResource StatusProtectedBrush}"
                                VerticalAlignment="Center" />
                            <TextBlock
                                Text="Son Tarama Özeti"
                                Style="{StaticResource TitleMediumTextStyle}"
                                VerticalAlignment="Center" />
                        </StackPanel>

                        <Grid ColumnSpacing="{StaticResource SpaceLg}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="MOD" Style="{StaticResource OverlineTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.LastCompletionModeTitle, Mode=OneWay}"
                                    Style="{StaticResource BodyLargeTextStyle}"
                                    FontWeight="SemiBold" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="TARİH" Style="{StaticResource OverlineTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.LastCompletionDateText, Mode=OneWay}"
                                    Style="{StaticResource BodyLargeTextStyle}"
                                    FontWeight="SemiBold" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="SÜRE" Style="{StaticResource OverlineTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.LastCompletionDurationText, Mode=OneWay}"
                                    Style="{StaticResource BodyLargeTextStyle}"
                                    FontWeight="SemiBold" />
                            </StackPanel>

                            <StackPanel Grid.Column="3" Spacing="4">
                                <TextBlock Text="TEHDİT" Style="{StaticResource OverlineTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.LastCompletionInfo.ThreatsFound, Mode=OneWay, FallbackValue=0}"
                                    Style="{StaticResource BodyLargeTextStyle}"
                                    FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ════════════════════════════════════════════════════════ -->
            <!-- ACTIVE STATE — tarama ilerleme                           -->
            <!-- ════════════════════════════════════════════════════════ -->
            <Border
                x:Name="ActiveStateCard"
                Style="{StaticResource HeroStatusCardStyle}"
                Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="{StaticResource SpaceXl}" HorizontalAlignment="Stretch">
                    <!-- Header -->
                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                        <TextBlock
                            Text="Tarama Devam Ediyor"
                            Style="{StaticResource DisplayMediumTextStyle}"
                            HorizontalAlignment="Center" />
                        <TextBlock
                            Text="{x:Bind ViewModel.SelectedModeTitle, Mode=OneWay}"
                            Style="{StaticResource BodyLargeTextStyle}"
                            Foreground="{ThemeResource TextSecondaryBrush}"
                            HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Ring -->
                    <controls:ProgressRingCard
                        Percent="{x:Bind ViewModel.Progress, Mode=OneWay}"
                        HorizontalAlignment="Center" />

                    <!-- Current path -->
                    <TextBlock
                        Text="{x:Bind ViewModel.CurrentPath, Mode=OneWay}"
                        Style="{StaticResource CaptionTextStyle}"
                        HorizontalAlignment="Center"
                        TextAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        MaxLines="1"
                        Foreground="{ThemeResource TextTertiaryBrush}" />

                    <!-- Stats -->
                    <Grid ColumnSpacing="{StaticResource SpaceXl}" MaxWidth="720" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="TARANAN DOSYA" Style="{StaticResource OverlineTextStyle}" HorizontalAlignment="Center" />
                            <TextBlock
                                Text="{x:Bind ViewModel.FilesScanned, Mode=OneWay}"
                                Style="{StaticResource DisplayMediumTextStyle}"
                                HorizontalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="BULUNAN TEHDİT" Style="{StaticResource OverlineTextStyle}" HorizontalAlignment="Center" />
                            <TextBlock
                                Text="{x:Bind ViewModel.ThreatsFound, Mode=OneWay}"
                                Style="{StaticResource DisplayMediumTextStyle}"
                                Foreground="{ThemeResource StatusRiskBrush}"
                                HorizontalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="SÜRE / KALAN" Style="{StaticResource OverlineTextStyle}" HorizontalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <TextBlock
                                    Text="{x:Bind ViewModel.ElapsedText, Mode=OneWay}"
                                    Style="{StaticResource DisplayMediumTextStyle}" />
                                <TextBlock
                                    Text="/"
                                    Style="{StaticResource DisplayMediumTextStyle}"
                                    Foreground="{ThemeResource TextTertiaryBrush}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.RemainingText, Mode=OneWay}"
                                    Style="{StaticResource DisplayMediumTextStyle}"
                                    Foreground="{ThemeResource TextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Action buttons -->
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="{StaticResource SpaceMd}"
                        HorizontalAlignment="Center">
                        <Button
                            Style="{StaticResource SubtleButtonStyle}"
                            Command="{x:Bind ViewModel.PauseResumeCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon
                                    Glyph="{x:Bind ViewModel.PauseResumeGlyph, Mode=OneWay}"
                                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                    FontSize="14" />
                                <TextBlock Text="{x:Bind ViewModel.PauseResumeText, Mode=OneWay}" />
                            </StackPanel>
                        </Button>
                        <Button
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{x:Bind ViewModel.CancelScanCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon
                                    Glyph="&#xE71A;"
                                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                    FontSize="14" />
                                <TextBlock Text="İptal Et" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</Page>