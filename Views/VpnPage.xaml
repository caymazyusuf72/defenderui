<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DefenderUI.Views.VpnPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:DefenderUI.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:DefenderUI.ViewModels"
    xmlns:local="using:DefenderUI.Views"
    mc:Ignorable="d"
    Background="{ThemeResource SurfaceBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Padding="{StaticResource PaddingPage}" Spacing="{StaticResource Space2xl}">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="VPN"
                           Style="{StaticResource DisplayMediumTextStyle}"
                           AutomationProperties.HeadingLevel="Level1" />
                <TextBlock Text="Güvenli ve özel internet erişimi"
                           Style="{StaticResource BodyLargeTextStyle}"
                           Foreground="{ThemeResource TextSecondaryBrush}" />
            </StackPanel>

            <!-- Hero: Connection Toggle -->
            <Border Style="{StaticResource HeroStatusCardStyle}" Padding="48" MinHeight="360">
                <StackPanel HorizontalAlignment="Center" Spacing="24">
                    <!-- Status Pill -->
                    <controls:StatusPill
                        Severity="{x:Bind local:VpnPage.GetPillSeverity(ViewModel.IsConnected), Mode=OneWay}"
                        Text="{x:Bind ViewModel.ConnectionStatus, Mode=OneWay}"
                        HorizontalAlignment="Center" />

                    <!-- Big Connect Button -->
                    <Button
                        Width="140"
                        Height="140"
                        CornerRadius="70"
                        Background="{x:Bind local:VpnPage.GetConnectBackground(ViewModel.IsConnected), Mode=OneWay}"
                        BorderThickness="0"
                        Padding="0"
                        HorizontalAlignment="Center"
                        Command="{x:Bind ViewModel.ToggleConnectionCommand}">
                        <Grid>
                            <FontIcon
                                Glyph="&#xE72E;"
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                FontSize="56"
                                Foreground="{ThemeResource TextOnAccentBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <!-- Toggle label -->
                    <TextBlock Text="{x:Bind ViewModel.ToggleButtonText, Mode=OneWay}"
                               Style="{StaticResource TitleMediumTextStyle}"
                               HorizontalAlignment="Center" />

                    <!-- Server info -->
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Text="Tercih edilen:"
                                   Style="{StaticResource BodyLargeTextStyle}"
                                   Foreground="{ThemeResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{x:Bind ViewModel.PreferredServer, Mode=OneWay}"
                                   Style="{StaticResource BodyLargeTextStyle}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <HyperlinkButton Content="Değiştir"
                                         Padding="4,0"
                                         Command="{x:Bind ViewModel.ChangeServerCommand}" />
                    </StackPanel>

                    <!-- Live stats when connected -->
                    <Grid ColumnSpacing="48"
                          HorizontalAlignment="Center"
                          Visibility="{x:Bind local:VpnPage.GetVisibility(ViewModel.IsConnected), Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="BAĞLANTI SÜRESİ" Style="{StaticResource OverlineTextStyle}" HorizontalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.ConnectionDuration, Mode=OneWay}"
                                       Style="{StaticResource TitleLargeTextStyle}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="İNDİRİLEN" Style="{StaticResource OverlineTextStyle}" HorizontalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.Downloaded, Mode=OneWay}"
                                       Style="{StaticResource TitleLargeTextStyle}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="YÜKLENEN" Style="{StaticResource OverlineTextStyle}" HorizontalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.Uploaded, Mode=OneWay}"
                                       Style="{StaticResource TitleLargeTextStyle}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Stats -->
            <Grid ColumnSpacing="{StaticResource SpaceLg}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <controls:StatCard Grid.Column="0"
                                    Glyph="&#xE916;"
                                    Label="AKTİF BAĞLANTI"
                                    Value="{x:Bind ViewModel.ActiveDurationStat, Mode=OneWay}" />
                <controls:StatCard Grid.Column="1"
                                    Glyph="&#xE968;"
                                    Label="BU AY KULLANIM"
                                    Value="{x:Bind ViewModel.MonthlyUsage, Mode=OneWay}" />
                <controls:StatCard Grid.Column="2"
                                    Glyph="&#xE774;"
                                    Label="BAĞLI SUNUCU"
                                    Value="{x:Bind ViewModel.ConnectedServer, Mode=OneWay}" />
            </Grid>

            <!-- Server List -->
            <StackPanel Spacing="16">
                <TextBlock Text="Sunucu Konumu Seç"
                           Style="{StaticResource TitleLargeTextStyle}"
                           AutomationProperties.HeadingLevel="Level2" />
                <Border Style="{StaticResource SurfaceCardStyle}" Padding="0">
                    <StackPanel>
                        <Grid Padding="16,12" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="ÜLKE" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Column="2" Text="ŞEHİR" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Column="3" Text="PING" Style="{StaticResource OverlineTextStyle}" Margin="0,0,16,0" />
                        </Grid>
                        <Rectangle Height="1" Fill="{ThemeResource DividerBrush}" />
                        <muxc:ItemsRepeater ItemsSource="{x:Bind ViewModel.Servers, Mode=OneWay}">
                            <muxc:ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:VpnServerItem">
                                    <Grid Padding="16,12" ColumnSpacing="12"
                                          BorderBrush="{ThemeResource DividerBrush}"
                                          BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind Flag}"
                                                   FontSize="22"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Country}"
                                                   Style="{StaticResource BodyLargeTextStyle}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind City}"
                                                   Style="{StaticResource BodyMediumTextStyle}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextSecondaryBrush}" />
                                        <Border Grid.Column="3"
                                                Background="{x:Bind local:VpnPage.GetPingBackground(Quality)}"
                                                CornerRadius="{StaticResource CornerRadiusPill}"
                                                Padding="10,3"
                                                Margin="0,0,16,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind PingText}"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Foreground="{x:Bind local:VpnPage.GetPingForeground(Quality)}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                        <Button Grid.Column="4"
                                                Content="Bağlan"
                                                Style="{StaticResource SecondaryActionButtonStyle}"
                                                Command="{Binding ElementName=RootPage, Path=ViewModel.ConnectToServerCommand}"
                                                CommandParameter="{x:Bind}" />
                                    </Grid>
                                </DataTemplate>
                            </muxc:ItemsRepeater.ItemTemplate>
                        </muxc:ItemsRepeater>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- VPN Features -->
            <StackPanel Spacing="16">
                <TextBlock Text="VPN Özellikleri"
                           Style="{StaticResource TitleLargeTextStyle}"
                           AutomationProperties.HeadingLevel="Level2" />
                <Grid ColumnSpacing="{StaticResource SpaceLg}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource InteractiveCardStyle}" Padding="20">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Width="40" Height="40">
                                <Ellipse Fill="{ThemeResource AccentSoftBrush}" />
                                <FontIcon Glyph="&#xE7E8;"
                                          FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                          FontSize="18"
                                          Foreground="{ThemeResource AccentPrimaryBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Kill Switch" Style="{StaticResource BodyLargeTextStyle}" FontWeight="SemiBold" />
                                <TextBlock Text="Bağlantı koparsa interneti anında kes"
                                           Style="{StaticResource CaptionTextStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="2"
                                          IsOn="{x:Bind ViewModel.KillSwitchEnabled, Mode=TwoWay}"
                                          MinWidth="0"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource InteractiveCardStyle}" Padding="20">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Width="40" Height="40">
                                <Ellipse Fill="{ThemeResource AccentSoftBrush}" />
                                <FontIcon Glyph="&#xE968;"
                                          FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                          FontSize="18"
                                          Foreground="{ThemeResource AccentPrimaryBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Split Tunneling" Style="{StaticResource BodyLargeTextStyle}" FontWeight="SemiBold" />
                                <TextBlock Text="Seçili uygulamaları VPN dışında tut"
                                           Style="{StaticResource CaptionTextStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="2"
                                          IsOn="{x:Bind ViewModel.SplitTunnelingEnabled, Mode=TwoWay}"
                                          MinWidth="0"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource InteractiveCardStyle}" Padding="20">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Width="40" Height="40">
                                <Ellipse Fill="{ThemeResource AccentSoftBrush}" />
                                <FontIcon Glyph="&#xE8BD;"
                                          FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                          FontSize="18"
                                          Foreground="{ThemeResource AccentPrimaryBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Otomatik Bağlan" Style="{StaticResource BodyLargeTextStyle}" FontWeight="SemiBold" />
                                <TextBlock Text="Güvensiz Wi-Fi algılandığında bağlan"
                                           Style="{StaticResource CaptionTextStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="2"
                                          IsOn="{x:Bind ViewModel.AutoConnectEnabled, Mode=TwoWay}"
                                          MinWidth="0"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- Upgrade CTA -->
            <Border Background="{ThemeResource AccentSoftBrush}"
                    CornerRadius="{StaticResource CornerRadiusCard}"
                    Padding="32">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0"
                              Glyph="&#xE734;"
                              FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                              FontSize="40"
                              Foreground="{ThemeResource AccentPrimaryBrush}"
                              VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="Sınırsız VPN için Premium'a Yükselt"
                                   Style="{StaticResource TitleMediumTextStyle}" />
                        <TextBlock Text="Aylık 10 GB sınırı yerine sınırsız trafik ve 50+ ülke."
                                   Style="{StaticResource BodyLargeTextStyle}"
                                   Foreground="{ThemeResource TextSecondaryBrush}" />
                    </StackPanel>
                    <Button Grid.Column="2"
                            Content="Premium'a Yükselt"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{x:Bind ViewModel.UpgradeToPremiumCommand}"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>