<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DefenderUI.Views.ProtectionPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:DefenderUI.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:helpers="using:DefenderUI.Helpers"
    xmlns:models="using:DefenderUI.Models"
    xmlns:local="using:DefenderUI.Views"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    Background="Transparent">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled">

        <StackPanel
            Padding="24"
            Spacing="32">

            <!-- ════════════════════════════════════════════════════════ -->
            <!-- Header                                                    -->
            <!-- ════════════════════════════════════════════════════════ -->
            <StackPanel x:Name="HeaderPanel" Spacing="4">
                <TextBlock
                    Text="Koruma Durumu"
                    Style="{StaticResource DisplayMediumTextStyle}"
                    AutomationProperties.HeadingLevel="Level1" />
                <TextBlock
                    Text="Tüm güvenlik modüllerini tek noktadan yönetin"
                    Style="{StaticResource BodyLargeTextStyle}"
                    Foreground="{ThemeResource TextSecondaryBrush}" />
            </StackPanel>

            <!-- ════════════════════════════════════════════════════════ -->
            <!-- Hero Status Card                                          -->
            <!-- ════════════════════════════════════════════════════════ -->
            <controls:StatusHeroCard
                x:Name="ProtectionHeroCard"
                Severity="{x:Bind ViewModel.OverallSeverity, Mode=OneWay}"
                Title="{x:Bind ViewModel.HeroTitle, Mode=OneWay}"
                SubTitle="{x:Bind ViewModel.HeroSubTitle, Mode=OneWay}"
                PrimaryActionText="Varsayılanlara Sıfırla"
                SecondaryActionText="Öneriler"
                PrimaryActionCommand="{x:Bind ViewModel.ResetToDefaultsCommand}"
                SecondaryActionCommand="{x:Bind ViewModel.ShowRecommendationsCommand}" />

            <!-- ════════════════════════════════════════════════════════ -->
            <!-- Temel Koruma Modülleri                                    -->
            <!-- ════════════════════════════════════════════════════════ -->
            <StackPanel Spacing="16">
                <TextBlock
                    x:Name="ModulesHeader"
                    Text="Temel Koruma Modülleri"
                    Style="{StaticResource TitleLargeTextStyle}"
                    AutomationProperties.HeadingLevel="Level2" />

                <muxc:ItemsRepeater ItemsSource="{x:Bind ViewModel.CoreModules, Mode=OneWay}">
                    <muxc:ItemsRepeater.Layout>
                        <muxc:UniformGridLayout
                            MinItemWidth="320"
                            MinItemHeight="180"
                            MinColumnSpacing="16"
                            MinRowSpacing="16"
                            ItemsStretch="Fill" />
                    </muxc:ItemsRepeater.Layout>
                    <muxc:ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:ProtectionModule">
                            <controls:ProtectionModuleCard
                                Glyph="{x:Bind Icon}"
                                Title="{x:Bind Name}"
                                Description="{x:Bind Description}"
                                IsModuleEnabled="{x:Bind IsEnabled, Mode=TwoWay}"
                                ConfigureCommand="{Binding ElementName=RootPage, Path=ViewModel.ConfigureModuleCommand}"
                                ConfigureCommandParameter="{x:Bind}" />
                        </DataTemplate>
                    </muxc:ItemsRepeater.ItemTemplate>
                </muxc:ItemsRepeater>
            </StackPanel>

            <!-- ════════════════════════════════════════════════════════ -->
            <!-- Gelişmiş Koruma                                           -->
            <!-- ════════════════════════════════════════════════════════ -->
            <StackPanel Spacing="16">
                <TextBlock
                    x:Name="AdvancedHeader"
                    Text="Gelişmiş Koruma"
                    Style="{StaticResource TitleLargeTextStyle}"
                    AutomationProperties.HeadingLevel="Level2" />

                <muxc:ItemsRepeater
                    x:Name="AdvancedGrid"
                    ItemsSource="{x:Bind ViewModel.AdvancedModules, Mode=OneWay}">
                    <muxc:ItemsRepeater.Layout>
                        <muxc:UniformGridLayout
                            MinItemWidth="320"
                            MinItemHeight="180"
                            MinColumnSpacing="16"
                            MinRowSpacing="16"
                            ItemsStretch="Fill" />
                    </muxc:ItemsRepeater.Layout>
                    <muxc:ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:ProtectionModule">
                            <controls:ProtectionModuleCard
                                Glyph="{x:Bind Icon}"
                                Title="{x:Bind Name}"
                                Description="{x:Bind Description}"
                                IsModuleEnabled="{x:Bind IsEnabled, Mode=TwoWay}"
                                ConfigureCommand="{Binding ElementName=RootPage, Path=ViewModel.ConfigureModuleCommand}"
                                ConfigureCommandParameter="{x:Bind}" />
                        </DataTemplate>
                    </muxc:ItemsRepeater.ItemTemplate>
                </muxc:ItemsRepeater>
            </StackPanel>

            <!-- ════════════════════════════════════════════════════════ -->
            <!-- Güvenlik Duvarı Özet                                      -->
            <!-- ════════════════════════════════════════════════════════ -->
            <StackPanel Spacing="16">
                <TextBlock
                    x:Name="FirewallHeader"
                    Text="Güvenlik Duvarı"
                    Style="{StaticResource TitleLargeTextStyle}"
                    AutomationProperties.HeadingLevel="Level2" />

                <Border x:Name="FirewallCard" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE83D;"
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                FontSize="20"
                                Foreground="{ThemeResource AccentPrimaryBrush}"
                                VerticalAlignment="Center" />

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock
                                    Text="Güvenlik Duvarı"
                                    Style="{StaticResource BodyLargeTextStyle}"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.FirewallProfile, Mode=OneWay}"
                                    Style="{StaticResource CaptionTextStyle}" />
                            </StackPanel>

                            <ToggleSwitch
                                Grid.Column="2"
                                IsOn="{x:Bind ViewModel.FirewallEnabled, Mode=TwoWay}"
                                MinWidth="0"
                                OnContent=""
                                OffContent=""
                                VerticalAlignment="Center" />
                        </Grid>

                        <Rectangle Height="1" Fill="{ThemeResource DividerBrush}" />

                        <Grid ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="BUGÜN ENGELLENEN" Style="{StaticResource OverlineTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.BlockedConnectionsToday, Mode=OneWay}"
                                    Style="{StaticResource TitleLargeTextStyle}"
                                    FontWeight="SemiBold" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="GELEN KURALLARI" Style="{StaticResource OverlineTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.InboundRules, Mode=OneWay}"
                                    Style="{StaticResource TitleLargeTextStyle}"
                                    FontWeight="SemiBold" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="GİDEN KURALLARI" Style="{StaticResource OverlineTextStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.OutboundRules, Mode=OneWay}"
                                    Style="{StaticResource TitleLargeTextStyle}"
                                    FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Command="{x:Bind ViewModel.ViewFirewallRulesCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon
                                        Glyph="&#xE8A7;"
                                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                        FontSize="14" />
                                    <TextBlock Text="Kuralları Göster" />
                                </StackPanel>
                            </Button>
                            <Button
                                Style="{StaticResource SubtleButtonStyle}"
                                Command="{x:Bind ViewModel.ResetFirewallCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon
                                        Glyph="&#xE72C;"
                                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                        FontSize="14" />
                                    <TextBlock Text="Sıfırla" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ════════════════════════════════════════════════════════ -->
            <!-- Son Koruma Olayları                                       -->
            <!-- ════════════════════════════════════════════════════════ -->
            <StackPanel Spacing="16">
                <TextBlock
                    Text="Son Koruma Olayları"
                    Style="{StaticResource TitleLargeTextStyle}"
                    AutomationProperties.HeadingLevel="Level2" />

                <Border Style="{StaticResource SurfaceCardStyle}" Padding="0">
                    <muxc:ItemsRepeater ItemsSource="{x:Bind ViewModel.RecentEvents, Mode=OneWay}">
                        <muxc:ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:ActivityLogItem">
                                <controls:ActivityListItem
                                    Glyph="{x:Bind local:ProtectionPage.GetActivityGlyph(Type)}"
                                    Title="{x:Bind Title}"
                                    Timestamp="{x:Bind local:ProtectionPage.FormatRelativeTime(Timestamp)}" />
                            </DataTemplate>
                        </muxc:ItemsRepeater.ItemTemplate>
                    </muxc:ItemsRepeater>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>