<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DefenderUI.Views.PasswordManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:DefenderUI.ViewModels"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Padding="{StaticResource PaddingPage}" Spacing="{StaticResource Space2xl}">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="Parola Yöneticisi"
                           Style="{StaticResource DisplayMediumTextStyle}"
                           AutomationProperties.HeadingLevel="Level1" />
                <TextBlock Text="Parolalarınızı güvenle saklayın ve yönetin"
                           Style="{StaticResource BodyLargeTextStyle}"
                           Foreground="{ThemeResource TextSecondaryBrush}" />
            </StackPanel>

            <!-- Hero Teaser -->
            <Border Style="{StaticResource HeroStatusCardStyle}" Padding="48">
                <StackPanel Spacing="20" HorizontalAlignment="Center">
                    <Grid Width="96" Height="96" HorizontalAlignment="Center">
                        <Ellipse Fill="{ThemeResource AccentSoftBrush}" />
                        <FontIcon Glyph="&#xE8D7;"
                                  FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                  FontSize="48"
                                  Foreground="{ThemeResource AccentPrimaryBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="Tüm parolalarınız tek bir güvenli kasada"
                               Style="{StaticResource TitleLargeTextStyle}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center" />
                    <TextBlock Text="AES-256 şifreleme, parola üreteci, oto-doldur ve karanlık web taraması — hepsi tek uygulamada."
                               Style="{StaticResource BodyLargeTextStyle}"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               MaxWidth="560"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Button Content="Kurulumu Başlat"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Command="{x:Bind ViewModel.StartSetupCommand}" />
                        <Button Content="Daha Fazla Bilgi"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Command="{x:Bind ViewModel.LearnMoreCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Features -->
            <StackPanel Spacing="16">
                <TextBlock Text="Özellikler"
                           Style="{StaticResource TitleLargeTextStyle}"
                           AutomationProperties.HeadingLevel="Level2" />
                <muxc:ItemsRepeater ItemsSource="{x:Bind ViewModel.Features, Mode=OneWay}">
                    <muxc:ItemsRepeater.Layout>
                        <muxc:UniformGridLayout MinItemWidth="280"
                                                MinItemHeight="140"
                                                MinRowSpacing="16"
                                                MinColumnSpacing="16" />
                    </muxc:ItemsRepeater.Layout>
                    <muxc:ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:PasswordFeatureItem">
                            <Border Style="{StaticResource InteractiveCardStyle}" Padding="20">
                                <StackPanel Spacing="10">
                                    <Grid Width="40" Height="40" HorizontalAlignment="Left">
                                        <Ellipse Fill="{ThemeResource AccentSoftBrush}" />
                                        <FontIcon Glyph="{x:Bind Glyph}"
                                                  FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                  FontSize="18"
                                                  Foreground="{ThemeResource AccentPrimaryBrush}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                    </Grid>
                                    <TextBlock Text="{x:Bind Title}"
                                               Style="{StaticResource BodyLargeTextStyle}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind Description}"
                                               Style="{StaticResource CaptionTextStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </muxc:ItemsRepeater.ItemTemplate>
                </muxc:ItemsRepeater>
            </StackPanel>

            <!-- Onboarding Steps -->
            <StackPanel Spacing="16">
                <TextBlock Text="Nasıl Çalışır?"
                           Style="{StaticResource TitleLargeTextStyle}"
                           AutomationProperties.HeadingLevel="Level2" />
                <muxc:ItemsRepeater ItemsSource="{x:Bind ViewModel.OnboardingSteps, Mode=OneWay}">
                    <muxc:ItemsRepeater.Layout>
                        <muxc:StackLayout Orientation="Vertical" Spacing="12" />
                    </muxc:ItemsRepeater.Layout>
                    <muxc:ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:OnboardingStep">
                            <Border Style="{StaticResource SurfaceCardStyle}" Padding="20">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Width="40" Height="40" VerticalAlignment="Top">
                                        <Ellipse Fill="{ThemeResource AccentPrimaryBrush}" />
                                        <TextBlock Text="{x:Bind StepNumberText}"
                                                   Foreground="{ThemeResource TextOnAccentBrush}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Title}"
                                                   Style="{StaticResource BodyLargeTextStyle}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Bind Description}"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </muxc:ItemsRepeater.ItemTemplate>
                </muxc:ItemsRepeater>
            </StackPanel>

            <!-- Premium CTA -->
            <Border Background="{ThemeResource AccentSoftBrush}"
                    CornerRadius="{StaticResource CornerRadiusCard}"
                    Padding="32">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- Faz D #23: AccentSoftBrush zemini üzerinde Dark temada
                         kontrast sınırda kalıyordu; AccentOnSoftBrush tema-aware
                         (Light: AccentPrimary, Dark: AccentSecondary) kullanılır. -->
                    <FontIcon Grid.Column="0"
                              Glyph="&#xE734;"
                              FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                              FontSize="40"
                              Foreground="{ThemeResource AccentOnSoftBrush}"
                              VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="Sınırsız parola için Premium'a yükselt"
                                   Style="{StaticResource TitleMediumTextStyle}" />
                        <TextBlock Text="50 parola sınırı yerine sınırsız kayıt, aile paylaşımı ve öncelikli destek."
                                   Style="{StaticResource BodyLargeTextStyle}"
                                   Foreground="{ThemeResource TextSecondaryBrush}" />
                    </StackPanel>
                    <Button Grid.Column="2"
                            Content="Premium'a Yükselt"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{x:Bind ViewModel.UpgradeToPremiumCommand}"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>