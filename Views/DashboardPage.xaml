<Page
    x:Class="DefenderUI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:DefenderUI.ViewModels"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    Background="{StaticResource AppBackgroundBrush}">

    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled">

        <StackPanel
            Padding="32"
            Spacing="24">

            <!-- ════════════════════════════════════════════════════ -->
            <!-- Section A - Page Header                             -->
            <!-- ════════════════════════════════════════════════════ -->
            <StackPanel x:Name="HeaderPanel" Spacing="4">
                <TextBlock
                    Text="Security Overview"
                    Style="{StaticResource TitleLargeStyle}"
                    AutomationProperties.HeadingLevel="Level1" />
                <TextBlock
                    Text="Real-time monitoring and threat detection"
                    Style="{StaticResource BodySecondaryStyle}" />
            </StackPanel>

            <!-- ════════════════════════════════════════════════════ -->
            <!-- Section B - Hero Card + KPI Grid                    -->
            <!-- ════════════════════════════════════════════════════ -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- Hero Protection Status Card -->
                <Border
                    x:Name="HeroCard"
                    Grid.Column="0"
                    Style="{StaticResource HeroCardStyle}"
                    AutomationProperties.Name="Protection status card">

                    <!-- Left accent stripe -->
                    <Border.Child>
                        <Grid>
                            <Border
                                Background="{StaticResource SuccessBrush}"
                                Width="4"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Stretch"
                                CornerRadius="2"
                                Margin="-32,0,0,0" />

                            <StackPanel Spacing="24">
                                <!-- Top row: Score + Status -->
                                <Grid ColumnSpacing="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Security Score Circle -->
                                    <Grid
                                        Grid.Column="0"
                                        Width="120"
                                        Height="120"
                                        AutomationProperties.Name="Security score">
                                        <Ellipse
                                            Width="120"
                                            Height="120"
                                            Stroke="{StaticResource BorderBrush}"
                                            StrokeThickness="3"
                                            Fill="Transparent" />
                                        <Ellipse
                                            x:Name="ScorePulseRing"
                                            Width="120"
                                            Height="120"
                                            Stroke="{StaticResource SuccessBrush}"
                                            StrokeThickness="4"
                                            Fill="Transparent"
                                            Opacity="0.3" />
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="0">
                                            <TextBlock
                                                Text="{x:Bind ViewModel.SecurityScore, Mode=OneWay}"
                                                Style="{StaticResource HeroNumberStyle}"
                                                Foreground="{StaticResource SuccessBrush}"
                                                HorizontalAlignment="Center" />
                                            <TextBlock
                                                Text="/100"
                                                Style="{StaticResource CaptionStyle}"
                                                HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Status Info -->
                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <FontIcon
                                                x:Name="ShieldIcon"
                                                Glyph="&#xE72E;"
                                                FontFamily="Segoe Fluent Icons"
                                                FontSize="28"
                                                Foreground="{StaticResource SuccessBrush}" />
                                            <TextBlock
                                                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                                Style="{StaticResource SubtitleStyle}" />
                                        </StackPanel>

                                        <TextBlock
                                            Text="{x:Bind ViewModel.StatusDescription, Mode=OneWay}"
                                            Style="{StaticResource BodySecondaryStyle}" />

                                        <!-- Protection status indicator -->
                                        <StackPanel
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            Margin="0,4,0,0">
                                            <Ellipse
                                                Width="10"
                                                Height="10"
                                                Fill="{StaticResource SuccessBrush}"
                                                VerticalAlignment="Center" />
                                            <TextBlock
                                                Text="Protected"
                                                Style="{StaticResource CaptionStyle}"
                                                Foreground="{StaticResource SuccessBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- Bottom row: Quick scan button + last scan info -->
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button
                                        Grid.Column="0"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{x:Bind ViewModel.QuickScanCommand}"
                                        AutomationProperties.Name="Run quick scan">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon
                                                Glyph="&#xE721;"
                                                FontFamily="Segoe Fluent Icons"
                                                FontSize="14" />
                                            <TextBlock Text="Run Quick Scan" />
                                        </StackPanel>
                                    </Button>

                                    <StackPanel
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="16"
                                        VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource CaptionStyle}">
                                            <Run Text="Last scan: " />
                                            <Run Text="{x:Bind ViewModel.LastScanDate, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" />
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource CaptionStyle}">
                                            <Run Text="Duration: " />
                                            <Run Text="{x:Bind ViewModel.LastScanDuration, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" />
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource CaptionStyle}">
                                            <Run Text="Files: " />
                                            <Run Text="{x:Bind ViewModel.LastScanFilesChecked, Mode=OneWay}" Foreground="{StaticResource TextPrimaryBrush}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border.Child>
                </Border>

                <!-- KPI Cards Grid (2x2) -->
                <Grid
                    Grid.Column="1"
                    RowSpacing="12"
                    ColumnSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- KPI 1: Threats Detected -->
                    <Border
                        x:Name="Kpi1"
                        Grid.Row="0"
                        Grid.Column="0"
                        Style="{StaticResource KpiCardStyle}"
                        AutomationProperties.Name="Threats detected">
                        <StackPanel Spacing="4">
                            <FontIcon
                                Glyph="&#xE7BA;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="18"
                                Foreground="{StaticResource DangerBrush}"
                                HorizontalAlignment="Left" />
                            <TextBlock
                                Text="{x:Bind ViewModel.ThreatsDetected, Mode=OneWay}"
                                Style="{StaticResource DisplayNumberStyle}"
                                Foreground="{StaticResource DangerBrush}" />
                            <TextBlock
                                Text="Threats Detected"
                                Style="{StaticResource CaptionStyle}" />
                        </StackPanel>
                    </Border>

                    <!-- KPI 2: Quarantined -->
                    <Border
                        x:Name="Kpi2"
                        Grid.Row="0"
                        Grid.Column="1"
                        Style="{StaticResource KpiCardStyle}"
                        AutomationProperties.Name="Quarantined items">
                        <StackPanel Spacing="4">
                            <FontIcon
                                Glyph="&#xF166;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="18"
                                Foreground="{StaticResource WarningBrush}"
                                HorizontalAlignment="Left" />
                            <TextBlock
                                Text="{x:Bind ViewModel.QuarantinedItems, Mode=OneWay}"
                                Style="{StaticResource DisplayNumberStyle}"
                                Foreground="{StaticResource WarningBrush}" />
                            <TextBlock
                                Text="Quarantined"
                                Style="{StaticResource CaptionStyle}" />
                        </StackPanel>
                    </Border>

                    <!-- KPI 3: Blocked Attacks -->
                    <Border
                        x:Name="Kpi3"
                        Grid.Row="1"
                        Grid.Column="0"
                        Style="{StaticResource KpiCardStyle}"
                        AutomationProperties.Name="Blocked attacks">
                        <StackPanel Spacing="4">
                            <FontIcon
                                Glyph="&#xE83B;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="18"
                                Foreground="{StaticResource AccentBrush}"
                                HorizontalAlignment="Left" />
                            <TextBlock
                                Text="{x:Bind ViewModel.BlockedAttacks, Mode=OneWay}"
                                Style="{StaticResource DisplayNumberStyle}"
                                Foreground="{StaticResource AccentBrush}" />
                            <TextBlock
                                Text="Blocked Attacks"
                                Style="{StaticResource CaptionStyle}" />
                        </StackPanel>
                    </Border>

                    <!-- KPI 4: Protected Files -->
                    <Border
                        x:Name="Kpi4"
                        Grid.Row="1"
                        Grid.Column="1"
                        Style="{StaticResource KpiCardStyle}"
                        AutomationProperties.Name="Protected files">
                        <StackPanel Spacing="4">
                            <FontIcon
                                Glyph="&#xE8B7;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="18"
                                Foreground="{StaticResource SuccessBrush}"
                                HorizontalAlignment="Left" />
                            <TextBlock
                                Text="{x:Bind ViewModel.ProtectedFiles, Mode=OneWay}"
                                Style="{StaticResource DisplayNumberStyle}"
                                Foreground="{StaticResource SuccessBrush}" />
                            <TextBlock
                                Text="Protected Files"
                                Style="{StaticResource CaptionStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ════════════════════════════════════════════════════ -->
            <!-- Section C - Quick Action Buttons                    -->
            <!-- ════════════════════════════════════════════════════ -->
            <TextBlock
                x:Name="QuickActionsHeader"
                Text="Quick Actions"
                Style="{StaticResource SubtitleStyle}"
                Margin="0,8,0,0"
                AutomationProperties.HeadingLevel="Level2" />

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Quick Scan -->
                <Button
                    x:Name="QuickAction1"
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    CornerRadius="8"
                    Command="{x:Bind ViewModel.QuickScanCommand}"
                    AutomationProperties.Name="Quick scan">
                    <Border Style="{StaticResource ActionCardStyle}" HorizontalAlignment="Stretch">
                        <StackPanel Spacing="8">
                            <Border
                                Width="40"
                                Height="40"
                                CornerRadius="10"
                                Background="{StaticResource AccentDarkBrush}"
                                HorizontalAlignment="Left">
                                <FontIcon
                                    Glyph="&#xE721;"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="18"
                                    Foreground="{StaticResource AccentLightBrush}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>
                            <TextBlock
                                Text="Quick Scan"
                                Style="{StaticResource BodyStyle}"
                                FontWeight="SemiBold" />
                            <TextBlock
                                Text="Fast check for common threats"
                                Style="{StaticResource CaptionStyle}" />
                        </StackPanel>
                    </Border>
                </Button>

                <!-- Full Scan -->
                <Button
                    x:Name="QuickAction2"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    CornerRadius="8"
                    Command="{x:Bind ViewModel.FullScanCommand}"
                    AutomationProperties.Name="Full scan">
                    <Border Style="{StaticResource ActionCardStyle}" HorizontalAlignment="Stretch">
                        <StackPanel Spacing="8">
                            <Border
                                Width="40"
                                Height="40"
                                CornerRadius="10"
                                Background="{StaticResource SuccessBackgroundBrush}"
                                HorizontalAlignment="Left">
                                <FontIcon
                                    Glyph="&#xEA18;"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="18"
                                    Foreground="{StaticResource SuccessBrush}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>
                            <TextBlock
                                Text="Full Scan"
                                Style="{StaticResource BodyStyle}"
                                FontWeight="SemiBold" />
                            <TextBlock
                                Text="Deep scan of entire system"
                                Style="{StaticResource CaptionStyle}" />
                        </StackPanel>
                    </Border>
                </Button>

                <!-- Custom Scan -->
                <Button
                    x:Name="QuickAction3"
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    CornerRadius="8"
                    Command="{x:Bind ViewModel.CustomScanCommand}"
                    AutomationProperties.Name="Custom scan">
                    <Border Style="{StaticResource ActionCardStyle}" HorizontalAlignment="Stretch">
                        <StackPanel Spacing="8">
                            <Border
                                Width="40"
                                Height="40"
                                CornerRadius="10"
                                Background="{StaticResource WarningBackgroundBrush}"
                                HorizontalAlignment="Left">
                                <FontIcon
                                    Glyph="&#xE8B7;"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="18"
                                    Foreground="{StaticResource WarningBrush}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>
                            <TextBlock
                                Text="Custom Scan"
                                Style="{StaticResource BodyStyle}"
                                FontWeight="SemiBold" />
                            <TextBlock
                                Text="Choose files or folders to scan"
                                Style="{StaticResource CaptionStyle}" />
                        </StackPanel>
                    </Border>
                </Button>

                <!-- Update Now -->
                <Button
                    x:Name="QuickAction4"
                    Grid.Column="3"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    CornerRadius="8"
                    Command="{x:Bind ViewModel.UpdateNowCommand}"
                    AutomationProperties.Name="Update definitions">
                    <Border Style="{StaticResource ActionCardStyle}" HorizontalAlignment="Stretch">
                        <StackPanel Spacing="8">
                            <Border
                                Width="40"
                                Height="40"
                                CornerRadius="10"
                                Background="{StaticResource CardBackgroundBrush}"
                                HorizontalAlignment="Left">
                                <FontIcon
                                    Glyph="&#xE895;"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="18"
                                    Foreground="{StaticResource InfoBrush}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>
                            <TextBlock
                                Text="Update Now"
                                Style="{StaticResource BodyStyle}"
                                FontWeight="SemiBold" />
                            <TextBlock
                                Text="Update virus definitions"
                                Style="{StaticResource CaptionStyle}" />
                        </StackPanel>
                    </Border>
                </Button>
            </Grid>

            <!-- ════════════════════════════════════════════════════ -->
            <!-- Section D - Real-time Protection + Update/Health    -->
            <!-- ════════════════════════════════════════════════════ -->
            <TextBlock
                x:Name="ProtectionSectionHeader"
                Text="Protection &amp; System Status"
                Style="{StaticResource SubtitleStyle}"
                Margin="0,8,0,0"
                AutomationProperties.HeadingLevel="Level2" />

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- Left: Real-time Protection Panel -->
                <Border
                    x:Name="ProtectionCard"
                    Grid.Column="0"
                    Style="{StaticResource DashboardCardStyle}"
                    AutomationProperties.Name="Real-time protection modules">
                    <StackPanel Spacing="16">
                        <!-- Card Header -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon
                                Glyph="&#xE72E;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="20"
                                Foreground="{StaticResource AccentBrush}" />
                            <TextBlock
                                Text="Real-time Protection"
                                Style="{StaticResource BodyLargeStyle}"
                                FontWeight="SemiBold" />
                        </StackPanel>

                        <Rectangle
                            Height="1"
                            Fill="{StaticResource BorderSubtleBrush}"
                            HorizontalAlignment="Stretch" />

                        <!-- Protection Module Rows -->
                        <!-- Module 1: Real-time Protection -->
                        <Grid ColumnSpacing="12" AutomationProperties.Name="Real-time Protection module">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE8BE;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="16"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                VerticalAlignment="Center" />
                            <TextBlock
                                Grid.Column="1"
                                Text="Real-time Protection"
                                Style="{StaticResource BodyStyle}"
                                VerticalAlignment="Center" />
                            <ToggleSwitch
                                Grid.Column="2"
                                IsOn="{x:Bind ViewModel.ProtectionModules[0].IsEnabled, Mode=OneWay}"
                                IsEnabled="False"
                                MinWidth="0"
                                MinHeight="0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Toggle real-time protection" />
                            <Ellipse
                                Grid.Column="3"
                                Width="10"
                                Height="10"
                                Fill="{StaticResource SuccessBrush}"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                        <!-- Module 2: Web Protection -->
                        <Grid ColumnSpacing="12" AutomationProperties.Name="Web Protection module">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE774;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="16"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                VerticalAlignment="Center" />
                            <TextBlock
                                Grid.Column="1"
                                Text="Web Protection"
                                Style="{StaticResource BodyStyle}"
                                VerticalAlignment="Center" />
                            <ToggleSwitch
                                Grid.Column="2"
                                IsOn="{x:Bind ViewModel.ProtectionModules[1].IsEnabled, Mode=OneWay}"
                                IsEnabled="False"
                                MinWidth="0"
                                MinHeight="0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Toggle web protection" />
                            <Ellipse
                                Grid.Column="3"
                                Width="10"
                                Height="10"
                                Fill="{StaticResource SuccessBrush}"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                        <!-- Module 3: File Protection -->
                        <Grid ColumnSpacing="12" AutomationProperties.Name="File Protection module">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE8A5;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="16"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                VerticalAlignment="Center" />
                            <TextBlock
                                Grid.Column="1"
                                Text="File Protection"
                                Style="{StaticResource BodyStyle}"
                                VerticalAlignment="Center" />
                            <ToggleSwitch
                                Grid.Column="2"
                                IsOn="{x:Bind ViewModel.ProtectionModules[2].IsEnabled, Mode=OneWay}"
                                IsEnabled="False"
                                MinWidth="0"
                                MinHeight="0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Toggle file protection" />
                            <Ellipse
                                Grid.Column="3"
                                Width="10"
                                Height="10"
                                Fill="{StaticResource SuccessBrush}"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                        <!-- Module 4: Ransomware Protection -->
                        <Grid ColumnSpacing="12" AutomationProperties.Name="Ransomware Protection module">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE72E;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="16"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                VerticalAlignment="Center" />
                            <TextBlock
                                Grid.Column="1"
                                Text="Ransomware Protection"
                                Style="{StaticResource BodyStyle}"
                                VerticalAlignment="Center" />
                            <ToggleSwitch
                                Grid.Column="2"
                                IsOn="{x:Bind ViewModel.ProtectionModules[3].IsEnabled, Mode=OneWay}"
                                IsEnabled="False"
                                MinWidth="0"
                                MinHeight="0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Toggle ransomware protection" />
                            <Ellipse
                                Grid.Column="3"
                                Width="10"
                                Height="10"
                                Fill="{StaticResource SuccessBrush}"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                        <!-- Module 5: Email Protection (Disabled) -->
                        <Grid ColumnSpacing="12" AutomationProperties.Name="Email Protection module">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE715;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="16"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                VerticalAlignment="Center" />
                            <TextBlock
                                Grid.Column="1"
                                Text="Email Protection"
                                Style="{StaticResource BodyStyle}"
                                VerticalAlignment="Center" />
                            <ToggleSwitch
                                Grid.Column="2"
                                IsOn="{x:Bind ViewModel.ProtectionModules[4].IsEnabled, Mode=OneWay}"
                                IsEnabled="False"
                                MinWidth="0"
                                MinHeight="0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Toggle email protection" />
                            <Ellipse
                                Grid.Column="3"
                                Width="10"
                                Height="10"
                                Fill="{StaticResource WarningBrush}"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                        <!-- Module 6: Network Protection -->
                        <Grid ColumnSpacing="12" AutomationProperties.Name="Network Protection module">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE968;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="16"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                VerticalAlignment="Center" />
                            <TextBlock
                                Grid.Column="1"
                                Text="Network Protection"
                                Style="{StaticResource BodyStyle}"
                                VerticalAlignment="Center" />
                            <ToggleSwitch
                                Grid.Column="2"
                                IsOn="{x:Bind ViewModel.ProtectionModules[5].IsEnabled, Mode=OneWay}"
                                IsEnabled="False"
                                MinWidth="0"
                                MinHeight="0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Toggle network protection" />
                            <Ellipse
                                Grid.Column="3"
                                Width="10"
                                Height="10"
                                Fill="{StaticResource SuccessBrush}"
                                VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Right: Update Status + System Health (stacked) -->
                <StackPanel Grid.Column="1" Spacing="16">

                    <!-- Update Status Card -->
                    <Border
                        x:Name="UpdateStatusCard"
                        Style="{StaticResource DashboardCardStyle}"
                        AutomationProperties.Name="Update status">
                        <StackPanel Spacing="12">
                            <!-- Card Header -->
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon
                                    Glyph="&#xE895;"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="20"
                                    Foreground="{StaticResource AccentBrush}" />
                                <TextBlock
                                    Text="Update Status"
                                    Style="{StaticResource BodyLargeStyle}"
                                    FontWeight="SemiBold" />
                            </StackPanel>

                            <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                            <!-- Virus Definitions -->
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Text="Virus Definitions"
                                    Style="{StaticResource CaptionStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.VirusDefinitionVersion, Mode=OneWay}"
                                    Style="{StaticResource BodyStyle}"
                                    FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon
                                        Glyph="&#xE73E;"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="12"
                                        Foreground="{StaticResource SuccessBrush}" />
                                    <TextBlock
                                        Text="Up to date"
                                        Style="{StaticResource CaptionStyle}"
                                        Foreground="{StaticResource SuccessBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <!-- App Version & Last Update -->
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="App Version" Style="{StaticResource CaptionStyle}" />
                                    <TextBlock
                                        Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                        Style="{StaticResource BodyStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Last Update" Style="{StaticResource CaptionStyle}" />
                                    <TextBlock
                                        Text="{x:Bind ViewModel.LastUpdateDate, Mode=OneWay}"
                                        Style="{StaticResource BodyStyle}" />
                                </StackPanel>
                            </Grid>

                            <Button
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                                AutomationProperties.Name="Check for updates">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon
                                        Glyph="&#xE895;"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="14" />
                                    <TextBlock Text="Check for Updates" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- System Health Card -->
                    <Border
                        x:Name="HealthCard"
                        Style="{StaticResource DashboardCardStyle}"
                        AutomationProperties.Name="System health information">
                        <StackPanel Spacing="12">
                            <!-- Card Header -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                                    <FontIcon
                                        Glyph="&#xE770;"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="20"
                                        Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock
                                        Text="System Health"
                                        Style="{StaticResource BodyLargeStyle}"
                                        FontWeight="SemiBold" />
                                </StackPanel>
                                <Border
                                    Grid.Column="1"
                                    Background="{StaticResource SuccessBackgroundBrush}"
                                    CornerRadius="12"
                                    Padding="10,4">
                                    <TextBlock
                                        Style="{StaticResource CaptionStyle}"
                                        Foreground="{StaticResource SuccessBrush}"
                                        FontWeight="Bold">
                                        <Run Text="{x:Bind ViewModel.HealthScore, Mode=OneWay}" />
                                        <Run Text="%" />
                                    </TextBlock>
                                </Border>
                            </Grid>

                            <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                            <!-- CPU Impact -->
                            <StackPanel Spacing="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="CPU Impact" Style="{StaticResource CaptionStyle}" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource CaptionStyle}" Foreground="{StaticResource SuccessBrush}">
                                        <Run Text="Low " />
                                        <Run Text="{x:Bind ViewModel.CpuImpact, Mode=OneWay}" />
                                        <Run Text="%" />
                                    </TextBlock>
                                </Grid>
                                <ProgressBar
                                    Value="{x:Bind ViewModel.CpuImpact, Mode=OneWay}"
                                    Maximum="100"
                                    Height="6"
                                    CornerRadius="3"
                                    Foreground="{StaticResource SuccessBrush}"
                                    Background="{StaticResource SurfaceBrush}" />
                            </StackPanel>

                            <!-- Memory Usage -->
                            <StackPanel Spacing="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Memory Usage" Style="{StaticResource CaptionStyle}" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource CaptionStyle}">
                                        <Run Text="{x:Bind ViewModel.MemoryUsage, Mode=OneWay}" />
                                        <Run Text=" MB" />
                                    </TextBlock>
                                </Grid>
                                <ProgressBar
                                    Value="{x:Bind ViewModel.MemoryUsage, Mode=OneWay}"
                                    Maximum="512"
                                    Height="6"
                                    CornerRadius="3"
                                    Foreground="{StaticResource AccentBrush}"
                                    Background="{StaticResource SurfaceBrush}" />
                            </StackPanel>

                            <!-- Auto Updates & Background -->
                            <Grid ColumnSpacing="8" RowSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <FontIcon
                                    Grid.Row="0" Grid.Column="0"
                                    Glyph="&#xE73E;"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="12"
                                    Foreground="{StaticResource SuccessBrush}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Grid.Row="0" Grid.Column="1"
                                    Text="Auto Updates On"
                                    Style="{StaticResource CaptionStyle}"
                                    VerticalAlignment="Center" />
                                <FontIcon
                                    Grid.Row="1" Grid.Column="0"
                                    Glyph="&#xE73E;"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="12"
                                    Foreground="{StaticResource SuccessBrush}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Grid.Row="1" Grid.Column="1"
                                    Text="Background Protection On"
                                    Style="{StaticResource CaptionStyle}"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ════════════════════════════════════════════════════ -->
            <!-- Section E - Activity Log + Alerts                   -->
            <!-- ════════════════════════════════════════════════════ -->
            <TextBlock
                x:Name="ActivitySectionHeader"
                Text="Activity &amp; Alerts"
                Style="{StaticResource SubtitleStyle}"
                Margin="0,8,0,0"
                AutomationProperties.HeadingLevel="Level2" />

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left: Recent Activity -->
                <Border
                    x:Name="ActivityCard"
                    Grid.Column="0"
                    Style="{StaticResource DashboardCardStyle}"
                    AutomationProperties.Name="Recent activity log">
                    <StackPanel Spacing="12">
                        <!-- Card Header -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon
                                Glyph="&#xE9D5;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="20"
                                Foreground="{StaticResource AccentBrush}" />
                            <TextBlock
                                Text="Recent Activity"
                                Style="{StaticResource BodyLargeStyle}"
                                FontWeight="SemiBold" />
                        </StackPanel>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                        <!-- Activity items -->
                        <!-- Item 1: Threat blocked -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE711;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Foreground="{StaticResource DangerBrush}"
                                VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock
                                    Text="{x:Bind ViewModel.RecentActivities[0].Title, Mode=OneWay}"
                                    Style="{StaticResource BodyStyle}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.RecentActivities[0].Description, Mode=OneWay}"
                                    Style="{StaticResource CaptionStyle}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="2"
                                Text="2h ago"
                                Style="{StaticResource CaptionTertiaryStyle}"
                                VerticalAlignment="Top" />
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                        <!-- Item 2: Scan completed -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE73E;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Foreground="{StaticResource SuccessBrush}"
                                VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock
                                    Text="{x:Bind ViewModel.RecentActivities[1].Title, Mode=OneWay}"
                                    Style="{StaticResource BodyStyle}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.RecentActivities[1].Description, Mode=OneWay}"
                                    Style="{StaticResource CaptionStyle}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="2"
                                Text="4h ago"
                                Style="{StaticResource CaptionTertiaryStyle}"
                                VerticalAlignment="Top" />
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                        <!-- Item 3: Database updated -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE895;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Foreground="{StaticResource AccentBrush}"
                                VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock
                                    Text="{x:Bind ViewModel.RecentActivities[2].Title, Mode=OneWay}"
                                    Style="{StaticResource BodyStyle}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.RecentActivities[2].Description, Mode=OneWay}"
                                    Style="{StaticResource CaptionStyle}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="2"
                                Text="6h ago"
                                Style="{StaticResource CaptionTertiaryStyle}"
                                VerticalAlignment="Top" />
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                        <!-- Item 4: File quarantined -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE7BA;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Foreground="{StaticResource WarningBrush}"
                                VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock
                                    Text="{x:Bind ViewModel.RecentActivities[3].Title, Mode=OneWay}"
                                    Style="{StaticResource BodyStyle}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.RecentActivities[3].Description, Mode=OneWay}"
                                    Style="{StaticResource CaptionStyle}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="2"
                                Text="1d ago"
                                Style="{StaticResource CaptionTertiaryStyle}"
                                VerticalAlignment="Top" />
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                        <!-- Item 5: Protection enabled -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE72E;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Foreground="{StaticResource SuccessBrush}"
                                VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock
                                    Text="{x:Bind ViewModel.RecentActivities[4].Title, Mode=OneWay}"
                                    Style="{StaticResource BodyStyle}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.RecentActivities[4].Description, Mode=OneWay}"
                                    Style="{StaticResource CaptionStyle}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="2"
                                Text="1d ago"
                                Style="{StaticResource CaptionTertiaryStyle}"
                                VerticalAlignment="Top" />
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                        <!-- Item 6: Warning -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE7BA;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Foreground="{StaticResource WarningBrush}"
                                VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock
                                    Text="{x:Bind ViewModel.RecentActivities[5].Title, Mode=OneWay}"
                                    Style="{StaticResource BodyStyle}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.RecentActivities[5].Description, Mode=OneWay}"
                                    Style="{StaticResource CaptionStyle}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="2"
                                Text="2d ago"
                                Style="{StaticResource CaptionTertiaryStyle}"
                                VerticalAlignment="Top" />
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                        <!-- Item 7: Full scan -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE73E;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Foreground="{StaticResource SuccessBrush}"
                                VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock
                                    Text="{x:Bind ViewModel.RecentActivities[6].Title, Mode=OneWay}"
                                    Style="{StaticResource BodyStyle}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.RecentActivities[6].Description, Mode=OneWay}"
                                    Style="{StaticResource CaptionStyle}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="2"
                                Text="3d ago"
                                Style="{StaticResource CaptionTertiaryStyle}"
                                VerticalAlignment="Top" />
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                        <!-- Item 8: Ransomware blocked -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                Glyph="&#xE711;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Foreground="{StaticResource DangerBrush}"
                                VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock
                                    Text="{x:Bind ViewModel.RecentActivities[7].Title, Mode=OneWay}"
                                    Style="{StaticResource BodyStyle}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.RecentActivities[7].Description, Mode=OneWay}"
                                    Style="{StaticResource CaptionStyle}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="2"
                                Text="5d ago"
                                Style="{StaticResource CaptionTertiaryStyle}"
                                VerticalAlignment="Top" />
                        </Grid>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                        <!-- View All Activity Link -->
                        <Button
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{x:Bind ViewModel.ViewAllActivityCommand}"
                            AutomationProperties.Name="View all activity">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <TextBlock
                                    Text="View All Activity"
                                    Style="{StaticResource BodyStyle}"
                                    Foreground="{StaticResource AccentBrush}" />
                                <FontIcon
                                    Glyph="&#xE76C;"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="12"
                                    Foreground="{StaticResource AccentBrush}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Right: Alerts & Recommendations -->
                <Border
                    x:Name="AlertsCard"
                    Grid.Column="1"
                    Style="{StaticResource DashboardCardStyle}"
                    AutomationProperties.Name="Alerts and recommendations">
                    <StackPanel Spacing="12">
                        <!-- Card Header -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon
                                Glyph="&#xE7BA;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="20"
                                Foreground="{StaticResource WarningBrush}" />
                            <TextBlock
                                Text="Alerts &amp; Recommendations"
                                Style="{StaticResource BodyLargeStyle}"
                                FontWeight="SemiBold" />
                        </StackPanel>

                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                        <!-- Alert 1: Scan overdue -->
                        <Border Style="{StaticResource AlertCardStyle}">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon
                                        Glyph="&#xE7BA;"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="14"
                                        Foreground="{StaticResource WarningBrush}" />
                                    <TextBlock
                                        Text="Scheduled scan overdue"
                                        Style="{StaticResource BodyStyle}"
                                        FontWeight="SemiBold" />
                                </StackPanel>
                                <TextBlock
                                    Text="Last scan was 3 days ago"
                                    Style="{StaticResource CaptionStyle}" />
                                <Button
                                    Content="Run Scan Now"
                                    HorizontalAlignment="Stretch"
                                    Command="{x:Bind ViewModel.RunScanNowCommand}"
                                    AutomationProperties.Name="Run scan now" />
                            </StackPanel>
                        </Border>

                        <!-- Alert 2: Quarantine items -->
                        <Border Style="{StaticResource AlertCardStyle}">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon
                                        Glyph="&#xE946;"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="14"
                                        Foreground="{StaticResource InfoBrush}" />
                                    <TextBlock
                                        Text="2 items in quarantine"
                                        Style="{StaticResource BodyStyle}"
                                        FontWeight="SemiBold" />
                                </StackPanel>
                                <TextBlock
                                    Text="Review and take action"
                                    Style="{StaticResource CaptionStyle}" />
                                <Button
                                    Content="View Quarantine"
                                    HorizontalAlignment="Stretch"
                                    Command="{x:Bind ViewModel.ViewQuarantineCommand}"
                                    AutomationProperties.Name="View quarantine" />
                            </StackPanel>
                        </Border>

                        <!-- Positive status items -->
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon
                                    Glyph="&#xE73E;"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Foreground="{StaticResource SuccessBrush}" />
                                <TextBlock
                                    Text="Definitions up to date"
                                    Style="{StaticResource CaptionStyle}"
                                    Foreground="{StaticResource SuccessBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon
                                    Glyph="&#xE73E;"
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Foreground="{StaticResource SuccessBrush}" />
                                <TextBlock
                                    Text="Firewall is active"
                                    Style="{StaticResource CaptionStyle}"
                                    Foreground="{StaticResource SuccessBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>