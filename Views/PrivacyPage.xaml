<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DefenderUI.Views.PrivacyPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:DefenderUI.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:models="using:DefenderUI.Models"
    xmlns:vm="using:DefenderUI.ViewModels"
    mc:Ignorable="d"
    Background="{ThemeResource SurfaceBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Padding="{StaticResource PaddingPage}" Spacing="{StaticResource Space2xl}">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="Gizlilik Koruması"
                           Style="{StaticResource DisplayMediumTextStyle}"
                           AutomationProperties.HeadingLevel="Level1" />
                <TextBlock Text="Kamera, mikrofon ve izleyici koruması tek noktadan"
                           Style="{StaticResource BodyLargeTextStyle}"
                           Foreground="{ThemeResource TextSecondaryBrush}" />
            </StackPanel>

            <!-- Hero -->
            <controls:StatusHeroCard
                Severity="{x:Bind ViewModel.OverallSeverity, Mode=OneWay}"
                Title="{x:Bind ViewModel.HeroTitle, Mode=OneWay}"
                SubTitle="{x:Bind ViewModel.HeroSubTitle, Mode=OneWay}"
                PrimaryActionText="Gizlilik Taraması Başlat"
                SecondaryActionText="Detayları Gör"
                PrimaryActionCommand="{x:Bind ViewModel.StartPrivacyScanCommand}"
                SecondaryActionCommand="{x:Bind ViewModel.ShowDetailsCommand}" />

            <!-- Privacy modules -->
            <StackPanel Spacing="16">
                <TextBlock Text="Gizlilik Modülleri"
                           Style="{StaticResource TitleLargeTextStyle}"
                           AutomationProperties.HeadingLevel="Level2" />
                <muxc:ItemsRepeater ItemsSource="{x:Bind ViewModel.PrivacyModules, Mode=OneWay}">
                    <muxc:ItemsRepeater.Layout>
                        <muxc:UniformGridLayout
                            MinItemWidth="320"
                            MinItemHeight="180"
                            MinColumnSpacing="16"
                            MinRowSpacing="16"
                            ItemsStretch="Fill" />
                    </muxc:ItemsRepeater.Layout>
                    <muxc:ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:ProtectionModule">
                            <controls:ProtectionModuleCard
                                Glyph="{x:Bind Icon}"
                                Title="{x:Bind Name}"
                                Description="{x:Bind Description}"
                                IsModuleEnabled="{x:Bind IsEnabled, Mode=TwoWay}"
                                ConfigureCommand="{Binding ElementName=RootPage, Path=ViewModel.ConfigureModuleCommand}"
                                ConfigureCommandParameter="{x:Bind}" />
                        </DataTemplate>
                    </muxc:ItemsRepeater.ItemTemplate>
                </muxc:ItemsRepeater>
            </StackPanel>

            <!-- Stats -->
            <StackPanel Spacing="16">
                <TextBlock Text="Son Engellemeler"
                           Style="{StaticResource TitleLargeTextStyle}"
                           AutomationProperties.HeadingLevel="Level2" />
                <Grid ColumnSpacing="{StaticResource SpaceLg}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <controls:StatCard Grid.Column="0"
                                        Glyph="&#xE727;"
                                        Label="BUGÜN ENGELLENEN"
                                        Value="{x:Bind ViewModel.TrackersToday, Mode=OneWay}" />
                    <controls:StatCard Grid.Column="1"
                                        Glyph="&#xE916;"
                                        Label="BU HAFTA"
                                        Value="{x:Bind ViewModel.TrackersWeek, Mode=OneWay}" />
                    <controls:StatCard Grid.Column="2"
                                        Glyph="&#xE9D2;"
                                        Label="TOPLAM"
                                        Value="{x:Bind ViewModel.TrackersTotal, Mode=OneWay}" />
                    <controls:StatCard Grid.Column="3"
                                        Glyph="&#xE960;"
                                        Label="KAMERA ERİŞİMİ"
                                        Value="{x:Bind ViewModel.CameraAccessAttempts, Mode=OneWay}" />
                </Grid>
            </StackPanel>

            <!-- App Permissions -->
            <StackPanel Spacing="16">
                <TextBlock Text="Uygulama İzinleri"
                           Style="{StaticResource TitleLargeTextStyle}"
                           AutomationProperties.HeadingLevel="Level2" />
                <Border Style="{StaticResource SurfaceCardStyle}" Padding="0">
                    <StackPanel>
                        <!-- Header Row -->
                        <Grid Padding="16,12" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="UYGULAMA" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Column="2" Text="İZİN TÜRÜ" Style="{StaticResource OverlineTextStyle}" Margin="0,0,24,0" />
                            <TextBlock Grid.Column="3" Text="DURUM" Style="{StaticResource OverlineTextStyle}" />
                        </Grid>
                        <Rectangle Height="1" Fill="{ThemeResource DividerBrush}" />
                        <muxc:ItemsRepeater ItemsSource="{x:Bind ViewModel.AppPermissions, Mode=OneWay}">
                            <muxc:ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:AppPermissionItem">
                                    <Grid Padding="16,12" ColumnSpacing="12"
                                          BorderBrush="{ThemeResource DividerBrush}"
                                          BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0" Width="32" Height="32">
                                            <Ellipse Fill="{ThemeResource AccentSoftBrush}" />
                                            <FontIcon Glyph="{x:Bind AppIcon}"
                                                      FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                      FontSize="14"
                                                      Foreground="{ThemeResource AccentPrimaryBrush}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                        </Grid>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind AppName}"
                                                   Style="{StaticResource BodyLargeTextStyle}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="2"
                                                Background="{ThemeResource AccentSoftBrush}"
                                                CornerRadius="{StaticResource CornerRadiusPill}"
                                                Padding="10,3"
                                                Margin="0,0,24,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind PermissionType}"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Foreground="{ThemeResource AccentPrimaryBrush}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                        <ToggleSwitch Grid.Column="3"
                                                      IsOn="{x:Bind IsAllowed, Mode=TwoWay}"
                                                      MinWidth="0"
                                                      OnContent=""
                                                      OffContent=""
                                                      VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </muxc:ItemsRepeater.ItemTemplate>
                        </muxc:ItemsRepeater>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>