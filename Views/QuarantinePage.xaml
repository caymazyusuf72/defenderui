<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DefenderUI.Views.QuarantinePage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:DefenderUI.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:helpers="using:DefenderUI.Helpers"
    xmlns:models="using:DefenderUI.Models"
    xmlns:local="using:DefenderUI.Views"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    Background="{ThemeResource SurfaceBackgroundBrush}">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled">

        <StackPanel
            Padding="24"
            Spacing="32">

            <!-- Header -->
            <StackPanel x:Name="HeaderPanel" Spacing="4">
                <TextBlock
                    Text="Karantina"
                    Style="{StaticResource DisplayMediumTextStyle}"
                    AutomationProperties.HeadingLevel="Level1" />
                <TextBlock
                    Text="Şüpheli dosyalar güvenle izole edildi"
                    Style="{StaticResource BodyLargeTextStyle}"
                    Foreground="{ThemeResource TextSecondaryBrush}" />
            </StackPanel>

            <!-- Stats row -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:StatCard
                    x:Name="KpiCard1"
                    Grid.Column="0"
                    Glyph="&#xE7B8;"
                    Label="TOPLAM ÖĞE"
                    Value="{x:Bind ViewModel.TotalQuarantined, Mode=OneWay}" />

                <controls:StatCard
                    x:Name="KpiCard2"
                    Grid.Column="1"
                    Glyph="&#xE783;"
                    Label="YÜKSEK RİSK"
                    Value="{x:Bind local:QuarantinePage.Sum(ViewModel.CriticalCount, ViewModel.HighCount), Mode=OneWay}" />

                <controls:StatCard
                    x:Name="KpiCard3"
                    Grid.Column="2"
                    Glyph="&#xE916;"
                    Label="BUGÜN"
                    Value="0" />

                <controls:StatCard
                    x:Name="KpiCard4"
                    Grid.Column="3"
                    Glyph="&#xE74D;"
                    Label="OTOMATİK TEMİZLİK (GÜN)"
                    Value="30" />
            </Grid>

            <!-- Items section -->
            <StackPanel Spacing="16">
                <TextBlock
                    Text="Karantinadaki Öğeler"
                    Style="{StaticResource TitleLargeTextStyle}"
                    AutomationProperties.HeadingLevel="Level2" />

                <Border x:Name="ToolbarCard" Style="{StaticResource SurfaceCardStyle}">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox
                            Grid.Column="0"
                            PlaceholderText="Tehdit adı veya yol ara..."
                            Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            VerticalAlignment="Center">
                            <TextBox.Resources>
                                <ResourceDictionary>
                                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                </ResourceDictionary>
                            </TextBox.Resources>
                        </TextBox>

                        <ComboBox
                            Grid.Column="1"
                            MinWidth="160"
                            SelectedIndex="{x:Bind ViewModel.SelectedRiskFilterIndex, Mode=TwoWay}"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Risk filtresi">
                            <ComboBoxItem Content="Tüm Riskler" />
                            <ComboBoxItem Content="Kritik" />
                            <ComboBoxItem Content="Yüksek" />
                            <ComboBoxItem Content="Orta" />
                            <ComboBoxItem Content="Düşük" />
                        </ComboBox>

                        <Button
                            Grid.Column="2"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{x:Bind ViewModel.RestoreSelectedCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon
                                    Glyph="&#xE777;"
                                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                    FontSize="14" />
                                <TextBlock Text="Seçilenleri Geri Yükle" />
                            </StackPanel>
                        </Button>

                        <Button
                            Grid.Column="3"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{x:Bind ViewModel.DeleteAllCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon
                                    Glyph="&#xE74D;"
                                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                    FontSize="14" />
                                <TextBlock Text="Tümünü Sil" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Border x:Name="ListContainer" Style="{StaticResource SurfaceCardStyle}" Padding="0">
                    <StackPanel>
                        <!-- List header -->
                        <Grid
                            Padding="16,12"
                            ColumnSpacing="12"
                            BorderBrush="{ThemeResource DividerBrush}"
                            BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>

                            <CheckBox
                                Grid.Column="0"
                                IsChecked="{x:Bind ViewModel.IsAllSelected, Mode=TwoWay}"
                                MinWidth="0"
                                Padding="0" />
                            <TextBlock Grid.Column="1" Text="TEHDİT" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Column="2" Text="DOSYA" Style="{StaticResource OverlineTextStyle}" Margin="8,0,0,0" />
                            <TextBlock Grid.Column="3" Text="AKSİYON" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Column="4" Text="TARİH" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Column="5" Text="RİSK" Style="{StaticResource OverlineTextStyle}" />
                        </Grid>

                        <ListView
                            x:Name="QuarantineList"
                            ItemsSource="{x:Bind ViewModel.FilteredItems, Mode=OneWay}"
                            SelectionMode="None"
                            Background="Transparent"
                            Visibility="{x:Bind ViewModel.HasFilteredItems, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="MinHeight" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ThreatInfo">
                                    <Grid
                                        Padding="16,10"
                                        ColumnSpacing="12"
                                        BorderBrush="{ThemeResource DividerBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox
                                            Grid.Column="0"
                                            IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                            MinWidth="0"
                                            Padding="0"
                                            VerticalAlignment="Center" />

                                        <FontIcon
                                            Grid.Column="1"
                                            Glyph="&#xE72E;"
                                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                            FontSize="18"
                                            Foreground="{x:Bind local:QuarantinePage.GetRiskBrush(RiskLevel), Mode=OneWay}"
                                            VerticalAlignment="Center" />

                                        <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <TextBlock
                                                Text="{x:Bind ThreatName}"
                                                Style="{StaticResource BodyMediumTextStyle}"
                                                FontWeight="SemiBold"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Text="{x:Bind FilePath}"
                                                Style="{StaticResource CaptionTextStyle}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <TextBlock
                                            Grid.Column="3"
                                            Text="{x:Bind ActionTaken}"
                                            Style="{StaticResource BodySmallTextStyle}"
                                            VerticalAlignment="Center" />

                                        <TextBlock
                                            Grid.Column="4"
                                            Text="{x:Bind local:QuarantinePage.FormatDate(DetectionDate)}"
                                            Style="{StaticResource CaptionTextStyle}"
                                            VerticalAlignment="Center" />

                                        <Border
                                            Grid.Column="5"
                                            Background="{x:Bind local:QuarantinePage.GetRiskSoftBrush(RiskLevel), Mode=OneWay}"
                                            CornerRadius="{StaticResource CornerRadiusPill}"
                                            Padding="10,3"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
                                            <TextBlock
                                                Text="{x:Bind local:QuarantinePage.GetRiskText(RiskLevel)}"
                                                Style="{StaticResource CaptionTextStyle}"
                                                Foreground="{x:Bind local:QuarantinePage.GetRiskBrush(RiskLevel), Mode=OneWay}"
                                                FontWeight="SemiBold" />
                                        </Border>

                                        <Button
                                            Grid.Column="6"
                                            Style="{StaticResource IconButtonStyle}"
                                            Width="32"
                                            Height="32"
                                            VerticalAlignment="Center">
                                            <FontIcon
                                                Glyph="&#xE712;"
                                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                FontSize="14" />
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem
                                                        Text="Geri Yükle"
                                                        Command="{Binding ElementName=RootPage, Path=ViewModel.RestoreItemCommand}"
                                                        CommandParameter="{x:Bind}">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE777;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutItem
                                                        Text="Kalıcı Olarak Sil"
                                                        Command="{Binding ElementName=RootPage, Path=ViewModel.DeleteItemCommand}"
                                                        CommandParameter="{x:Bind}">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Empty state -->
                        <StackPanel
                            Padding="24,64"
                            Spacing="12"
                            HorizontalAlignment="Center"
                            Visibility="{x:Bind ViewModel.HasFilteredItems, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                            <FontIcon
                                Glyph="&#xE7B8;"
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                FontSize="48"
                                Foreground="{ThemeResource TextTertiaryBrush}"
                                HorizontalAlignment="Center" />
                            <TextBlock
                                Text="Karantinada öğe yok"
                                Style="{StaticResource TitleMediumTextStyle}"
                                HorizontalAlignment="Center" />
                            <TextBlock
                                Text="Filtre kriterleriyle eşleşen öğe bulunmuyor."
                                Style="{StaticResource CaptionTextStyle}"
                                HorizontalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Temizlik Politikası -->
            <StackPanel Spacing="16">
                <TextBlock
                    Text="Temizlik Politikası"
                    Style="{StaticResource TitleLargeTextStyle}"
                    AutomationProperties.HeadingLevel="Level2" />

                <Border Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock
                            Text="Karantinaya alınmış öğeler belirlenen süre sonra otomatik olarak silinir. Önemli bir öğeyi silmeden önce gözden geçirmek için otomatik temizlik periyodunu düzenleyebilirsiniz."
                            Style="{StaticResource BodyMediumTextStyle}"
                            TextWrapping="Wrap"
                            Foreground="{ThemeResource TextSecondaryBrush}" />

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                <TextBlock
                                    Text="Otomatik temizlik periyodu"
                                    Style="{StaticResource BodyLargeTextStyle}"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    Text="Bu süreden daha eski öğeler otomatik olarak silinir."
                                    Style="{StaticResource CaptionTextStyle}" />
                            </StackPanel>

                            <ComboBox
                                Grid.Column="1"
                                MinWidth="140"
                                SelectedIndex="2"
                                VerticalAlignment="Center">
                                <ComboBoxItem Content="7 gün" />
                                <ComboBoxItem Content="14 gün" />
                                <ComboBoxItem Content="30 gün" />
                                <ComboBoxItem Content="90 gün" />
                                <ComboBoxItem Content="Asla" />
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>