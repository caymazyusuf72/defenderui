<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DefenderUI.Views.UpdatePage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:DefenderUI.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:helpers="using:DefenderUI.Helpers"
    xmlns:models="using:DefenderUI.Models"
    xmlns:local="using:DefenderUI.Views"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    Background="Transparent">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled">

        <StackPanel
            Padding="24"
            Spacing="32">

            <!-- Header -->
            <StackPanel x:Name="HeaderPanel" Spacing="4">
                <TextBlock
                    Text="Güncellemeler"
                    Style="{StaticResource DisplayMediumTextStyle}"
                    AutomationProperties.HeadingLevel="Level1" />
                <TextBlock
                    Text="Veri tabanı, motor ve uygulama güncellemelerini yönetin"
                    Style="{StaticResource BodyLargeTextStyle}"
                    Foreground="{ThemeResource TextSecondaryBrush}" />
            </StackPanel>

            <!-- Hero Status -->
            <controls:StatusHeroCard
                x:Name="HeroCard"
                Severity="{x:Bind local:UpdatePage.GetSeverity(ViewModel.IsUpdateAvailable), Mode=OneWay}"
                Title="{x:Bind local:UpdatePage.GetHeroTitle(ViewModel.IsUpdateAvailable, ViewModel.IsUpdating), Mode=OneWay}"
                SubTitle="{x:Bind ViewModel.UpdateStatusText, Mode=OneWay}"
                PrimaryActionText="{x:Bind local:UpdatePage.GetPrimaryActionText(ViewModel.IsUpdateAvailable, ViewModel.IsUpdating), Mode=OneWay}"
                SecondaryActionText="Yeniden Kontrol Et"
                PrimaryActionCommand="{x:Bind local:UpdatePage.GetPrimaryCommand(ViewModel, ViewModel.IsUpdateAvailable), Mode=OneWay}"
                SecondaryActionCommand="{x:Bind ViewModel.CheckForUpdatesCommand}" />

            <!-- Update progress bar (only while installing) -->
            <Border
                Style="{StaticResource SurfaceCardStyle}"
                Visibility="{x:Bind ViewModel.IsUpdating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Text="{x:Bind ViewModel.UpdateStatusText, Mode=OneWay}"
                            Style="{StaticResource BodyMediumTextStyle}" />
                        <Button
                            Grid.Column="1"
                            Style="{StaticResource SubtleButtonStyle}"
                            Command="{x:Bind ViewModel.CancelUpdateCommand}"
                            Content="İptal" />
                    </Grid>
                    <ProgressBar
                        Value="{x:Bind ViewModel.UpdateProgress, Mode=OneWay}"
                        Maximum="100"
                        Height="8"
                        CornerRadius="4"
                        Foreground="{ThemeResource AccentPrimaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Stats row -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:StatCard
                    x:Name="VirusDefinitionsCard"
                    Grid.Column="0"
                    Glyph="&#xE895;"
                    Label="İMZA VERİTABANI"
                    Value="{x:Bind ViewModel.VirusDefinitionVersion, Mode=OneWay}" />

                <controls:StatCard
                    x:Name="ApplicationCard"
                    Grid.Column="1"
                    Glyph="&#xE74C;"
                    Label="MOTOR SÜRÜMÜ"
                    Value="{x:Bind ViewModel.AppVersion, Mode=OneWay}" />

                <controls:StatCard
                    Grid.Column="2"
                    Glyph="&#xE916;"
                    Label="SON KONTROL"
                    Value="{x:Bind local:UpdatePage.FormatRelative(ViewModel.LastUpdateDate), Mode=OneWay}" />

                <controls:StatCard
                    Grid.Column="3"
                    Glyph="&#xE72E;"
                    Label="OTOMATİK GÜNCELLEME"
                    Value="{x:Bind local:UpdatePage.OnOff(ViewModel.AutoUpdateEnabled), Mode=OneWay}" />
            </Grid>

            <!-- Update Settings -->
            <StackPanel Spacing="16">
                <TextBlock
                    Text="Güncelleme Ayarları"
                    Style="{StaticResource TitleLargeTextStyle}"
                    AutomationProperties.HeadingLevel="Level2" />

                <Grid x:Name="UpdateSettingsCard" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource InteractiveCardStyle}">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon
                                    Glyph="&#xE895;"
                                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                    FontSize="18"
                                    Foreground="{ThemeResource AccentPrimaryBrush}" />
                                <TextBlock
                                    Text="Otomatik Güncelleme"
                                    Style="{StaticResource BodyLargeTextStyle}"
                                    FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock
                                Text="Yeni güncellemeler yayımlandığında otomatik indir ve yükle."
                                Style="{StaticResource CaptionTextStyle}"
                                TextWrapping="Wrap" />
                            <ToggleSwitch
                                IsOn="{x:Bind ViewModel.AutoUpdateEnabled, Mode=TwoWay}"
                                MinWidth="0"
                                OnContent="Açık"
                                OffContent="Kapalı"
                                HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource InteractiveCardStyle}">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon
                                    Glyph="&#xE774;"
                                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                    FontSize="18"
                                    Foreground="{ThemeResource AccentPrimaryBrush}" />
                                <TextBlock
                                    Text="Güncelleme Kanalı"
                                    Style="{StaticResource BodyLargeTextStyle}"
                                    FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock
                                Text="Stable kanal önerilir. Beta ve Preview kanalları deneyseldir."
                                Style="{StaticResource CaptionTextStyle}"
                                TextWrapping="Wrap" />
                            <ComboBox SelectedIndex="0" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Stable" />
                                <ComboBoxItem Content="Preview" />
                                <ComboBoxItem Content="Beta" />
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource InteractiveCardStyle}">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon
                                    Glyph="&#xE839;"
                                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                    FontSize="18"
                                    Foreground="{ThemeResource AccentPrimaryBrush}" />
                                <TextBlock
                                    Text="Ölçülü Ağda İndir"
                                    Style="{StaticResource BodyLargeTextStyle}"
                                    FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock
                                Text="Mobil veri gibi ölçülü ağ bağlantılarında güncelleme indirmeye izin ver."
                                Style="{StaticResource CaptionTextStyle}"
                                TextWrapping="Wrap" />
                            <ToggleSwitch
                                IsOn="{x:Bind ViewModel.MeteredConnectionUpdate, Mode=TwoWay}"
                                MinWidth="0"
                                OnContent="Açık"
                                OffContent="Kapalı"
                                HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- Update History -->
            <StackPanel Spacing="16">
                <TextBlock
                    Text="Güncelleme Geçmişi"
                    Style="{StaticResource TitleLargeTextStyle}"
                    AutomationProperties.HeadingLevel="Level2" />

                <Border x:Name="HistoryCard" Style="{StaticResource SurfaceCardStyle}" Padding="0">
                    <StackPanel>
                        <Grid
                            Padding="16,12"
                            ColumnSpacing="12"
                            BorderBrush="{ThemeResource DividerBrush}"
                            BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SÜRÜM" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Column="1" Text="TÜR" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Column="2" Text="TARİH" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Column="3" Text="BOYUT" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Column="4" Text="DURUM" Style="{StaticResource OverlineTextStyle}" />
                        </Grid>

                        <ListView
                            x:Name="HistoryList"
                            ItemsSource="{x:Bind ViewModel.UpdateHistory, Mode=OneWay}"
                            SelectionMode="None"
                            Background="Transparent"
                            ScrollViewer.VerticalScrollMode="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled"
                            ScrollViewer.HorizontalScrollMode="Disabled"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="MinHeight" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:UpdateHistoryItem">
                                    <Grid
                                        Padding="16,12"
                                        ColumnSpacing="12"
                                        BorderBrush="{ThemeResource DividerBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Text="{x:Bind Version}"
                                            Style="{StaticResource BodyMediumTextStyle}"
                                            FontWeight="SemiBold"
                                            VerticalAlignment="Center" />

                                        <Border
                                            Grid.Column="1"
                                            Background="{ThemeResource AccentSoftBrush}"
                                            CornerRadius="{StaticResource CornerRadiusPill}"
                                            Padding="10,3"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
                                            <TextBlock
                                                Text="{x:Bind Type}"
                                                Style="{StaticResource CaptionTextStyle}"
                                                Foreground="{ThemeResource AccentPrimaryBrush}"
                                                FontWeight="SemiBold" />
                                        </Border>

                                        <TextBlock
                                            Grid.Column="2"
                                            Text="{x:Bind local:UpdatePage.FormatDate(Date)}"
                                            Style="{StaticResource CaptionTextStyle}"
                                            VerticalAlignment="Center" />

                                        <TextBlock
                                            Grid.Column="3"
                                            Text="{x:Bind Size}"
                                            Style="{StaticResource BodyMediumTextStyle}"
                                            VerticalAlignment="Center" />

                                        <StackPanel
                                            Grid.Column="4"
                                            Orientation="Horizontal"
                                            Spacing="6"
                                            VerticalAlignment="Center">
                                            <FontIcon
                                                Glyph="{x:Bind local:UpdatePage.GetStatusGlyph(Success)}"
                                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                FontSize="14"
                                                Foreground="{x:Bind local:UpdatePage.GetStatusBrush(Success), Mode=OneWay}" />
                                            <TextBlock
                                                Text="{x:Bind local:UpdatePage.GetStatusText(Success)}"
                                                Style="{StaticResource CaptionTextStyle}"
                                                Foreground="{x:Bind local:UpdatePage.GetStatusBrush(Success), Mode=OneWay}"
                                                FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>