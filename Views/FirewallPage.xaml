<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DefenderUI.Views.FirewallPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:DefenderUI.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:models="using:DefenderUI.Models"
    xmlns:vm="using:DefenderUI.ViewModels"
    xmlns:local="using:DefenderUI.Views"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Padding="{StaticResource PaddingPage}" Spacing="{StaticResource Space2xl}">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="Güvenlik Duvarı"
                           Style="{StaticResource DisplayMediumTextStyle}"
                           AutomationProperties.HeadingLevel="Level1" />
                <TextBlock Text="Ağ trafiğini izleyin ve kural yönetimini yapın"
                           Style="{StaticResource BodyLargeTextStyle}"
                           Foreground="{ThemeResource TextSecondaryBrush}" />
            </StackPanel>

            <!-- Hero -->
            <controls:StatusHeroCard
                Severity="{x:Bind ViewModel.OverallSeverity, Mode=OneWay}"
                Title="{x:Bind ViewModel.HeroTitle, Mode=OneWay}"
                SubTitle="{x:Bind ViewModel.HeroSubTitle, Mode=OneWay}"
                PrimaryActionText="Kural Ekle"
                SecondaryActionText="Ağ Trafiğini İzle"
                PrimaryActionCommand="{x:Bind ViewModel.AddRuleCommand}"
                SecondaryActionCommand="{x:Bind ViewModel.MonitorTrafficCommand}" />

            <!-- Stats -->
            <Grid ColumnSpacing="{StaticResource SpaceLg}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <controls:StatCard Grid.Column="0"
                                    Glyph="&#xE785;"
                                    Label="BUGÜN ENGELLENEN"
                                    Value="{x:Bind ViewModel.BlockedToday, Mode=OneWay}" />
                <controls:StatCard Grid.Column="1"
                                    Glyph="&#xE8A7;"
                                    Label="AKTİF KURAL"
                                    Value="{x:Bind ViewModel.ActiveRules, Mode=OneWay}" />
                <controls:StatCard Grid.Column="2"
                                    Glyph="&#xE896;"
                                    Label="GELEN TRAFİK"
                                    Value="{x:Bind ViewModel.InboundTraffic, Mode=OneWay}" />
                <controls:StatCard Grid.Column="3"
                                    Glyph="&#xE898;"
                                    Label="GİDEN TRAFİK"
                                    Value="{x:Bind ViewModel.OutboundTraffic, Mode=OneWay}" />
            </Grid>

            <!-- Network Profile -->
            <StackPanel Spacing="16">
                <TextBlock Text="Ağ Profili"
                           Style="{StaticResource TitleLargeTextStyle}"
                           AutomationProperties.HeadingLevel="Level2" />
                <Grid ColumnSpacing="{StaticResource SpaceLg}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Private -->
                    <Border Grid.Column="0" Style="{StaticResource InteractiveCardStyle}" Padding="20">
                        <StackPanel Spacing="12">
                            <Grid Width="48" Height="48" HorizontalAlignment="Left">
                                <Ellipse Fill="{ThemeResource AccentSoftBrush}" />
                                <FontIcon Glyph="&#xE80F;"
                                          FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                          FontSize="22"
                                          Foreground="{ThemeResource AccentPrimaryBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Özel Ağ" Style="{StaticResource TitleMediumTextStyle}" />
                                <TextBlock Text="Ev ağınız güvenli. Dosya paylaşımı etkin."
                                           Style="{StaticResource CaptionTextStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <RadioButton Content="Aktif Profil"
                                         GroupName="NetworkProfile"
                                         IsChecked="{x:Bind ViewModel.IsPrivateSelected, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>

                    <!-- Public -->
                    <Border Grid.Column="1" Style="{StaticResource InteractiveCardStyle}" Padding="20">
                        <StackPanel Spacing="12">
                            <Grid Width="48" Height="48" HorizontalAlignment="Left">
                                <Ellipse Fill="{ThemeResource StatusWarningSoftBrush}" />
                                <FontIcon Glyph="&#xE774;"
                                          FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                          FontSize="22"
                                          Foreground="{ThemeResource StatusWarningBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Genel Ağ" Style="{StaticResource TitleMediumTextStyle}" />
                                <TextBlock Text="Kafeler, havaalanları gibi halka açık ağlar."
                                           Style="{StaticResource CaptionTextStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <RadioButton Content="Aktif Profil Değil"
                                         GroupName="NetworkProfile"
                                         IsChecked="{x:Bind ViewModel.IsPublicSelected, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>

                    <!-- Domain -->
                    <Border Grid.Column="2" Style="{StaticResource InteractiveCardStyle}" Padding="20">
                        <StackPanel Spacing="12">
                            <Grid Width="48" Height="48" HorizontalAlignment="Left">
                                <Ellipse Fill="{ThemeResource AccentSoftBrush}" />
                                <FontIcon Glyph="&#xE821;"
                                          FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                          FontSize="22"
                                          Foreground="{ThemeResource AccentPrimaryBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Spacing="4">
                                <TextBlock Text="İş Ağı" Style="{StaticResource TitleMediumTextStyle}" />
                                <TextBlock Text="Kurumsal ağ yapılandırması."
                                           Style="{StaticResource CaptionTextStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <RadioButton Content="Aktif Profil Değil"
                                         GroupName="NetworkProfile"
                                         IsChecked="{x:Bind ViewModel.IsDomainSelected, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- Application Rules -->
            <StackPanel Spacing="16">
                <TextBlock Text="Uygulama Kuralları"
                           Style="{StaticResource TitleLargeTextStyle}"
                           AutomationProperties.HeadingLevel="Level2" />
                <Border Style="{StaticResource SurfaceCardStyle}" Padding="0">
                    <StackPanel>
                        <Grid Padding="16,12" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="UYGULAMA" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Column="2" Text="YOL" Style="{StaticResource OverlineTextStyle}" />
                            <TextBlock Grid.Column="3" Text="TÜR" Style="{StaticResource OverlineTextStyle}" Margin="0,0,16,0" />
                            <TextBlock Grid.Column="4" Text="YÖN" Style="{StaticResource OverlineTextStyle}" Margin="0,0,16,0" />
                            <TextBlock Grid.Column="5" Text="DURUM" Style="{StaticResource OverlineTextStyle}" Margin="0,0,16,0" />
                        </Grid>
                        <Rectangle Height="1" Fill="{ThemeResource DividerBrush}" />
                        <muxc:ItemsRepeater x:Name="RulesRepeater" ItemsSource="{x:Bind ViewModel.ApplicationRules, Mode=OneWay}">
                            <muxc:ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:FirewallRuleItem">
                                    <Grid Padding="16,12" ColumnSpacing="12"
                                          BorderBrush="{ThemeResource DividerBrush}"
                                          BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0" Width="32" Height="32">
                                            <Ellipse Fill="{ThemeResource AccentSoftBrush}" />
                                            <FontIcon Glyph="{x:Bind Icon}"
                                                      FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                      FontSize="14"
                                                      Foreground="{ThemeResource AccentPrimaryBrush}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                        </Grid>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind AppName}"
                                                   Style="{StaticResource BodyLargeTextStyle}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind AppPath}"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Border Grid.Column="3"
                                                Background="{x:Bind local:FirewallPage.GetActionBrush(IsAllow)}"
                                                CornerRadius="{StaticResource CornerRadiusPill}"
                                                Padding="10,3"
                                                Margin="0,0,16,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Action}"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Foreground="{x:Bind local:FirewallPage.GetActionForeground(IsAllow)}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Grid.Column="4"
                                                   Text="{x:Bind Direction}"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,0" />
                                        <ToggleSwitch Grid.Column="5"
                                                      IsOn="{x:Bind IsEnabled, Mode=TwoWay}"
                                                      MinWidth="0"
                                                      OnContent=""
                                                      OffContent=""
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0" />
                                        <Button Grid.Column="6"
                                                Style="{StaticResource IconButtonStyle}"
                                                Command="{Binding ElementName=RootPage, Path=ViewModel.EditRuleCommand}"
                                                CommandParameter="{x:Bind}">
                                            <FontIcon Glyph="&#xE712;"
                                                      FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                      FontSize="14" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </muxc:ItemsRepeater.ItemTemplate>
                        </muxc:ItemsRepeater>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Recent Blocks -->
            <StackPanel Spacing="16">
                <TextBlock Text="Son Engellemeler"
                           Style="{StaticResource TitleLargeTextStyle}"
                           AutomationProperties.HeadingLevel="Level2" />
                <Border Style="{StaticResource SurfaceCardStyle}" Padding="0">
                    <muxc:ItemsRepeater x:Name="RecentBlocksRepeater" ItemsSource="{x:Bind ViewModel.RecentBlocks, Mode=OneWay}">
                        <muxc:ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:ActivityLogItem">
                                <controls:ActivityListItem
                                    Glyph="&#xE785;"
                                    Title="{x:Bind Title}"
                                    Timestamp="{x:Bind local:FirewallPage.FormatRelativeTime(Timestamp)}" />
                            </DataTemplate>
                        </muxc:ItemsRepeater.ItemTemplate>
                    </muxc:ItemsRepeater>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>