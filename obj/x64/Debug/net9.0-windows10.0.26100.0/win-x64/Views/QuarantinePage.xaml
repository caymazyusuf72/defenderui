<Page x:ConnectionId='1'
    x:Class="DefenderUI.Views.QuarantinePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:DefenderUI.Helpers"
    xmlns:models="using:DefenderUI.Models"
    mc:Ignorable="d"
    Background="{StaticResource AppBackgroundBrush}">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════ -->
        <!-- Section A - Page Header                             -->
        <!-- ════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Spacing="4" Padding="32,32,32,0">
            <TextBlock
                Text="Quarantine"
                Style="{StaticResource TitleLargeStyle}"
                AutomationProperties.HeadingLevel="Level1" />
            <TextBlock
                Text="Manage quarantined threats and take action"
                Style="{StaticResource BodySecondaryStyle}" />
        </StackPanel>

        <!-- ════════════════════════════════════════════════════ -->
        <!-- Section B - KPI Summary Cards                       -->
        <!-- ════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Padding="32,24,32,0" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Total Quarantined -->
            <Border Grid.Column="0" Style="{StaticResource KpiCardStyle}"
                    AutomationProperties.Name="Total quarantined items">
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock x:ConnectionId='26'
                                                                               
                        Style="{StaticResource DisplayNumberStyle}"
                        Foreground="{StaticResource AccentBrush}"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        Text="Total Quarantined"
                        Style="{StaticResource CaptionStyle}"
                        HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Critical -->
            <Border Grid.Column="1" Style="{StaticResource KpiCardStyle}"
                    AutomationProperties.Name="Critical threats count">
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock x:ConnectionId='25'
                                                                            
                        Style="{StaticResource DisplayNumberStyle}"
                        Foreground="{StaticResource DangerBrush}"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        Text="Critical"
                        Style="{StaticResource CaptionStyle}"
                        HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- High -->
            <Border Grid.Column="2" Style="{StaticResource KpiCardStyle}"
                    AutomationProperties.Name="High risk threats count">
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock x:ConnectionId='24'
                                                                        
                        Style="{StaticResource DisplayNumberStyle}"
                        Foreground="{StaticResource WarningBrush}"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        Text="High"
                        Style="{StaticResource CaptionStyle}"
                        HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Medium -->
            <Border Grid.Column="3" Style="{StaticResource KpiCardStyle}"
                    AutomationProperties.Name="Medium risk threats count">
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock x:ConnectionId='23'
                                                                          
                        Style="{StaticResource DisplayNumberStyle}"
                        Foreground="#D29922"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        Text="Medium"
                        Style="{StaticResource CaptionStyle}"
                        HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════════════════ -->
        <!-- Section C - Toolbar (Filters + Actions)             -->
        <!-- ════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Style="{StaticResource DashboardCardStyle}"
                Margin="32,16,32,0"
                AutomationProperties.Name="Quarantine toolbar">
            <StackPanel Spacing="12">
                <!-- Filters Row -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Search Box -->
                    <TextBox x:ConnectionId='20'
                        Grid.Column="0"
                        PlaceholderText="&#xE721; Search threats..."
                                                                                                               
                        FontFamily="Segoe Fluent Icons"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        AutomationProperties.Name="Search quarantined threats" />

                    <!-- Risk Filter -->
                    <ComboBox x:ConnectionId='21'
                        Grid.Column="1"
                                                                                               
                        MinWidth="140"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        AutomationProperties.Name="Filter by risk level">
                        <ComboBoxItem Content="All Risks" />
                        <ComboBoxItem Content="Critical" />
                        <ComboBoxItem Content="High" />
                        <ComboBoxItem Content="Medium" />
                        <ComboBoxItem Content="Low" />
                    </ComboBox>

                    <!-- Date Filter -->
                    <ComboBox x:ConnectionId='22'
                        Grid.Column="2"
                                                                                               
                        MinWidth="140"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        AutomationProperties.Name="Filter by date">
                        <ComboBoxItem Content="Last 24 hours" />
                        <ComboBoxItem Content="Last 7 days" />
                        <ComboBoxItem Content="Last 30 days" />
                        <ComboBoxItem Content="All Time" />
                    </ComboBox>
                </Grid>

                <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" HorizontalAlignment="Stretch" />

                <!-- Actions Row -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <CheckBox x:ConnectionId='15'
                        Grid.Column="0"
                        Content="Select All"
                                                                                 
                        Foreground="{StaticResource TextPrimaryBrush}"
                        AutomationProperties.Name="Select all quarantined items" />

                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource CaptionStyle}"
                        VerticalAlignment="Center">
                        <Run x:ConnectionId='19'                                                      />
                        <Run Text=" selected" />
                    </TextBlock>

                    <!-- Spacer -->
                    <Border Grid.Column="2" />

                    <Button x:ConnectionId='16'
                        Grid.Column="3"
                        Style="{StaticResource SecondaryButtonStyle}"
                                                                           
                        Padding="12,6"
                        AutomationProperties.Name="Restore selected items">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                            <TextBlock Text="Restore Selected" />
                        </StackPanel>
                    </Button>

                    <Button x:ConnectionId='17'
                        Grid.Column="4"
                        Style="{StaticResource SecondaryButtonStyle}"
                                                                          
                        Padding="12,6"
                        AutomationProperties.Name="Delete selected items">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                            <TextBlock Text="Delete Selected" />
                        </StackPanel>
                    </Button>

                    <Button x:ConnectionId='18'
                        Grid.Column="5"
                        Style="{StaticResource DangerButtonStyle}"
                                                                     
                        Padding="12,6"
                        AutomationProperties.Name="Delete all quarantined items">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                            <TextBlock Text="Delete All" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════ -->
        <!-- Section D - Threat List + Empty State               -->
        <!-- ════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3" Padding="32,16,32,32">

            <!-- Empty State -->
            <Border x:ConnectionId='2'
                Style="{StaticResource DashboardCardStyle}"
                                                                                                                                                              
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                AutomationProperties.Name="No quarantined items">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    Padding="40">
                    <FontIcon
                        Glyph="&#xE72E;"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="48"
                        Foreground="{StaticResource SuccessBrush}"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        Text="No quarantined items found"
                        Style="{StaticResource SubtitleStyle}"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        Text="Your device is clean and protected"
                        Style="{StaticResource BodySecondaryStyle}"
                        HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Threat List -->
            <ScrollViewer x:ConnectionId='3'
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                                                                                                                                   >
                <ItemsRepeater x:ConnectionId='4'
                                                                               >
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate                               >
                            <Border x:ConnectionId='6'
                                Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16"
                                                                               >
                                <Grid>
                                    <!-- Left color stripe based on risk -->
                                    <Border
                                        Width="4"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        CornerRadius="2"
                                        Margin="-16,0,0,0"
                                        Background="{StaticResource DangerBrush}" />

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- CheckBox -->
                                        <CheckBox x:ConnectionId='7'
                                            Grid.Column="0"
                                                                                        
                                            VerticalAlignment="Top"
                                            Margin="0,2,0,0"
                                            AutomationProperties.Name="Select threat item" />

                                        <!-- Risk Icon -->
                                        <Border
                                            Grid.Column="1"
                                            Width="36"
                                            Height="36"
                                            CornerRadius="18"
                                            VerticalAlignment="Top"
                                            Margin="0,2,0,0"
                                            Background="{StaticResource DangerBackgroundBrush}">
                                            <FontIcon
                                                Glyph="&#xE711;"
                                                FontFamily="Segoe Fluent Icons"
                                                FontSize="16"
                                                Foreground="{StaticResource DangerBrush}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Content -->
                                        <StackPanel Grid.Column="2" Spacing="4">
                                            <!-- Threat name + badge -->
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock x:ConnectionId='13'
                                                                              
                                                    Style="{StaticResource BodyLargeStyle}"
                                                    FontWeight="SemiBold" />
                                                <!-- Risk Badge -->
                                                <Border
                                                    CornerRadius="4"
                                                    Padding="8,2"
                                                    VerticalAlignment="Center"
                                                    Background="{StaticResource DangerBackgroundBrush}">
                                                    <TextBlock x:ConnectionId='14'
                                                                                 
                                                        FontSize="11"
                                                        FontWeight="SemiBold"
                                                        Foreground="{StaticResource DangerBrush}" />
                                                </Border>
                                            </StackPanel>

                                            <!-- File path -->
                                            <TextBlock x:ConnectionId='9'
                                                                        
                                                Style="{StaticResource CaptionStyle}"
                                                TextTrimming="CharacterEllipsis"
                                                MaxLines="1" />

                                            <!-- Action info -->
                                            <TextBlock Style="{StaticResource CaptionStyle}">
                                                <Run Text="Action: " />
                                                <Run x:ConnectionId='12'                             />
                                            </TextBlock>

                                            <!-- Action Buttons -->
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                                <Button x:ConnectionId='10'
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Padding="10,4"
                                                    FontSize="12"
                                                                  
                                                                              
                                                    AutomationProperties.Name="Restore this threat">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon Glyph="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="12" />
                                                        <TextBlock Text="Restore" FontSize="12" />
                                                    </StackPanel>
                                                </Button>
                                                <Button x:ConnectionId='11'
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Padding="10,4"
                                                    FontSize="12"
                                                                  
                                                                             
                                                    AutomationProperties.Name="Delete this threat permanently">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="12" />
                                                        <TextBlock Text="Delete" FontSize="12" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Date -->
                                        <TextBlock x:ConnectionId='8'
                                            Grid.Column="3"
                                                                         
                                            Style="{StaticResource CaptionStyle}"
                                            VerticalAlignment="Top"
                                            Margin="0,4,0,0" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>

