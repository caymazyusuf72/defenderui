<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="DefenderUI.Views.UpdatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:DefenderUI.Helpers"
    mc:Ignorable="d"
                        
    Background="Transparent">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="32" Spacing="16">

            <!-- Header -->
            <StackPanel x:ConnectionId='2' x:Name="HeaderPanel">
                <TextBlock Text="Update"
                           Style="{StaticResource TitleLargeStyle}" />
                <TextBlock Text="Keep your protection up to date"
                           Style="{StaticResource BodySecondaryStyle}"
                           Margin="0,4,0,0" />
            </StackPanel>

            <!-- Update Status Hero Card -->
            <Border x:ConnectionId='3' x:Name="HeroCard" Style="{StaticResource HeroCardStyle}">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe Fluent Icons"
                                   FontSize="20" Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Update Status"
                                   Style="{StaticResource SubtitleStyle}" />
                    </StackPanel>

                    <!-- Up to date state (no update, not complete) -->
                    <StackPanel x:ConnectionId='13'                                                                                                                                                
                                Spacing="8">
                        <StackPanel x:ConnectionId='25'                                                                                                                                               >
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                           FontSize="24" Foreground="{StaticResource SuccessBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Your system is up to date"
                                           Style="{StaticResource BodyLargeStyle}"
                                           Foreground="{StaticResource SuccessBrush}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource BodySecondaryStyle}" Margin="0,4,0,0">
                                <Run Text="DefenderUI v" />
                                <Run x:ConnectionId='28'                                                   />
                                <Run Text=" is the latest version." />
                            </TextBlock>
                        </StackPanel>

                        <!-- Update complete state -->
                        <StackPanel x:ConnectionId='26'                                                                                                                    
                                    Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                           FontSize="24" Foreground="{StaticResource SuccessBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Update completed successfully!"
                                           Style="{StaticResource BodyLargeStyle}"
                                           Foreground="{StaticResource SuccessBrush}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource BodySecondaryStyle}">
                                <Run Text="DefenderUI has been updated to v" />
                                <Run x:ConnectionId='27'                                                   />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- Update available state -->
                    <StackPanel x:ConnectionId='14'                                                                                                                     
                                Spacing="12">

                        <!-- Not updating -->
                        <StackPanel x:ConnectionId='15'                                                                                                                                         
                                    Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons"
                                           FontSize="24" Foreground="{StaticResource WarningBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Update Available"
                                           Style="{StaticResource BodyLargeStyle}"
                                           Foreground="{StaticResource WarningBrush}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold" />
                            </StackPanel>

                            <TextBlock Style="{StaticResource BodyStyle}">
                                <Run Text="DefenderUI v" />
                                <Run x:ConnectionId='24'                                                               />
                                <Run Text=" is available" />
                            </TextBlock>

                            <TextBlock Style="{StaticResource BodySecondaryStyle}">
                                <Run Text="Current: v" />
                                <Run x:ConnectionId='22'                                                   />
                                <Run Text=" → New: v" />
                                <Run x:ConnectionId='23'                                                               />
                            </TextBlock>

                            <TextBlock Style="{StaticResource BodySecondaryStyle}">
                                <Run Text="Size: " />
                                <Run x:ConnectionId='21'                                                   />
                            </TextBlock>

                            <!-- Changelog -->
                            <StackPanel Spacing="4" Margin="0,4,0,0">
                                <TextBlock Text="What's new:" Style="{StaticResource BodyStyle}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="• Improved real-time scanning engine"
                                           Style="{StaticResource BodySecondaryStyle}" />
                                <TextBlock Text="• Fixed false positive detection"
                                           Style="{StaticResource BodySecondaryStyle}" />
                                <TextBlock Text="• Enhanced ransomware protection"
                                           Style="{StaticResource BodySecondaryStyle}" />
                                <TextBlock Text="• Performance improvements"
                                           Style="{StaticResource BodySecondaryStyle}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                <Button x:ConnectionId='20' Content="Download &amp; Install"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                                                                       
                                        AutomationProperties.Name="Download and install update" />
                                <Button Content="Remind Me Later"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        AutomationProperties.Name="Remind me later about update" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Updating progress -->
                        <StackPanel x:ConnectionId='16'                                                                                                              
                                    Spacing="12">
                            <TextBlock x:ConnectionId='17'                                                        
                                       Style="{StaticResource BodyLargeStyle}"
                                       FontWeight="SemiBold" />

                            <ProgressBar x:ConnectionId='18'                                                       
                                         Maximum="100"
                                         Height="8"
                                         CornerRadius="4"
                                         Foreground="{StaticResource AccentBrush}"
                                         Background="{StaticResource SurfaceBrush}" />

                            <Button x:ConnectionId='19' Content="Cancel"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                                    
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="Cancel update" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Version Info Cards -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Virus Definitions -->
                <Border Grid.Column="0" Style="{StaticResource DashboardCardStyle}">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Foreground="{StaticResource SuccessBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Virus Definitions"
                                       Style="{StaticResource SubtitleStyle}" />
                        </StackPanel>

                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Version"
                                       Style="{StaticResource BodySecondaryStyle}"
                                       VerticalAlignment="Center" />
                            <TextBlock x:ConnectionId='12' Grid.Row="0" Grid.Column="1"
                                                                                                    
                                       Style="{StaticResource BodyStyle}"
                                       VerticalAlignment="Center" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Last updated"
                                       Style="{StaticResource BodySecondaryStyle}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Today 08:30"
                                       Style="{StaticResource BodyStyle}"
                                       VerticalAlignment="Center" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Status"
                                       Style="{StaticResource BodySecondaryStyle}"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                           FontSize="14" Foreground="{StaticResource SuccessBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Up to date"
                                           Style="{StaticResource BodyStyle}"
                                           Foreground="{StaticResource SuccessBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <Button x:ConnectionId='11' Content="Check Now"
                                Style="{StaticResource SecondaryButtonStyle}"
                                                                                   
                                HorizontalAlignment="Left"
                                AutomationProperties.Name="Check for virus definition updates" />
                    </StackPanel>
                </Border>

                <!-- Application -->
                <Border Grid.Column="1" Style="{StaticResource DashboardCardStyle}">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&#xE71D;" FontFamily="Segoe Fluent Icons"
                                       FontSize="18" Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Application"
                                       Style="{StaticResource SubtitleStyle}" />
                        </StackPanel>

                        <Grid RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Version"
                                       Style="{StaticResource BodySecondaryStyle}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Style="{StaticResource BodyStyle}"
                                       VerticalAlignment="Center">
                                <Run Text="v" />
                                <Run x:ConnectionId='10'                                                   />
                            </TextBlock>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Last updated"
                                       Style="{StaticResource BodySecondaryStyle}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Apr 10"
                                       Style="{StaticResource BodyStyle}"
                                       VerticalAlignment="Center" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Status"
                                       Style="{StaticResource BodySecondaryStyle}"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons"
                                           FontSize="14" Foreground="{StaticResource WarningBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Update available"
                                           Style="{StaticResource BodyStyle}"
                                           Foreground="{StaticResource WarningBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <Button x:ConnectionId='9' Content="Check Now"
                                Style="{StaticResource SecondaryButtonStyle}"
                                                                                   
                                HorizontalAlignment="Left"
                                AutomationProperties.Name="Check for application updates" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Update Settings -->
            <Border Style="{StaticResource DashboardCardStyle}">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons"
                                   FontSize="18" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Update Settings"
                                   Style="{StaticResource SubtitleStyle}" />
                    </StackPanel>

                    <!-- Auto App Updates -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Automatic App Updates"
                                       Style="{StaticResource BodyStyle}" />
                            <TextBlock Text="Download and install app updates automatically"
                                       Style="{StaticResource CaptionStyle}" />
                        </StackPanel>
                        <ToggleSwitch x:ConnectionId='8' Grid.Column="1"                                                         
                                      OffContent="" OnContent=""
                                      AutomationProperties.Name="Automatic app updates toggle" />
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderSubtleBrush}" />

                    <!-- Auto Definition Updates -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Automatic Virus Definition Updates"
                                       Style="{StaticResource BodyStyle}" />
                            <TextBlock Text="Keep virus definitions up to date automatically"
                                       Style="{StaticResource CaptionStyle}" />
                        </StackPanel>
                        <ToggleSwitch x:ConnectionId='7' Grid.Column="1"                                                            
                                      OffContent="" OnContent=""
                                      AutomationProperties.Name="Automatic virus definition updates toggle" />
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderSubtleBrush}" />

                    <!-- Metered Connection -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Download on metered connections"
                                       Style="{StaticResource BodyStyle}" />
                            <TextBlock Text="Allow updates over metered network connections"
                                       Style="{StaticResource CaptionStyle}" />
                        </StackPanel>
                        <ToggleSwitch x:ConnectionId='6' Grid.Column="1"                                                               
                                      OffContent="" OnContent=""
                                      AutomationProperties.Name="Metered connection updates toggle" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Update History -->
            <Border Style="{StaticResource DashboardCardStyle}">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons"
                                   FontSize="18" Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Update History"
                                   Style="{StaticResource SubtitleStyle}" />
                    </StackPanel>

                    <!-- Table Header -->
                    <Grid Padding="12,8" Background="{StaticResource SurfaceBrush}" CornerRadius="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*" />
                            <ColumnDefinition Width="1.5*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Version"
                                   Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="Type"
                                   Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2" Text="Date"
                                   Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="3" Text="Size"
                                   Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="4" Text="Status"
                                   Style="{StaticResource CaptionStyle}" FontWeight="SemiBold" />
                    </Grid>

                    <!-- Table Rows -->
                    <ItemsRepeater x:ConnectionId='4'                                                            >
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="2" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12,10" CornerRadius="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.5*" />
                                        <ColumnDefinition Width="1.5*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="0.8*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding Version}"
                                               Style="{StaticResource BodyStyle}"
                                               VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="1" Text="{Binding Type}"
                                               Style="{StaticResource BodySecondaryStyle}"
                                               VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Date}"
                                               Style="{StaticResource CaptionStyle}"
                                               VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="3" Text="{Binding Size}"
                                               Style="{StaticResource CaptionStyle}"
                                               VerticalAlignment="Center" />

                                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons"
                                                   FontSize="12" Foreground="{StaticResource SuccessBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="Success"
                                                   Style="{StaticResource CaptionStyle}"
                                                   Foreground="{StaticResource SuccessBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

