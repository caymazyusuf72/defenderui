<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Background Colors                                          -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="AppBackgroundColor">#0D1117</Color>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />

    <Color x:Key="CardBackgroundColor">#161B22</Color>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />

    <Color x:Key="CardBackgroundHoverColor">#1C2333</Color>
    <SolidColorBrush x:Key="CardBackgroundHoverBrush" Color="{StaticResource CardBackgroundHoverColor}" />

    <Color x:Key="SurfaceColor">#21262D</Color>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Border Colors                                              -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="BorderColor">#30363D</Color>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />

    <Color x:Key="BorderSubtleColor">#21262D</Color>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Text Colors                                                -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="TextPrimaryColor">#F0F6FC</Color>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />

    <Color x:Key="TextSecondaryColor">#8B949E</Color>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />

    <Color x:Key="TextTertiaryColor">#6E7681</Color>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Accent Colors                                              -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="AccentColor">#58A6FF</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />

    <Color x:Key="AccentLightColor">#79C0FF</Color>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}" />

    <Color x:Key="AccentDarkColor">#1F6FEB</Color>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Status Colors                                              -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="SuccessColor">#3FB950</Color>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />

    <Color x:Key="SuccessBackgroundColor">#0D2818</Color>
    <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="{StaticResource SuccessBackgroundColor}" />

    <Color x:Key="WarningColor">#D29922</Color>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />

    <Color x:Key="WarningBackgroundColor">#2D1F00</Color>
    <SolidColorBrush x:Key="WarningBackgroundBrush" Color="{StaticResource WarningBackgroundColor}" />

    <Color x:Key="DangerColor">#F85149</Color>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />

    <Color x:Key="DangerBackgroundColor">#3D1012</Color>
    <SolidColorBrush x:Key="DangerBackgroundBrush" Color="{StaticResource DangerBackgroundColor}" />

    <Color x:Key="InfoColor">#58A6FF</Color>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- Navigation Colors                                          -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Color x:Key="NavigationBackgroundColor">#010409</Color>
    <SolidColorBrush x:Key="NavigationBackgroundBrush" Color="{StaticResource NavigationBackgroundColor}" />

    <Color x:Key="NavigationItemHoverColor">#161B22</Color>
    <SolidColorBrush x:Key="NavigationItemHoverBrush" Color="{StaticResource NavigationItemHoverColor}" />

    <Color x:Key="NavigationItemSelectedColor">#1F6FEB</Color>
    <SolidColorBrush x:Key="NavigationItemSelectedBrush" Color="{StaticResource NavigationItemSelectedColor}" />

</ResourceDictionary>
