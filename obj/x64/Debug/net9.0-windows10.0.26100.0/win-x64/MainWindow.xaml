<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="DefenderUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DefenderUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DefenderUI"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:ConnectionId='2'
            x:Name="AppTitleBarGrid"
            Grid.Row="0"
            Height="48"
            Padding="16,0"
            Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel
                Grid.Column="0"
                Orientation="Horizontal"
                Spacing="8"
                VerticalAlignment="Center">
                <FontIcon
                    Glyph="&#xE72E;"
                    FontSize="16"
                    Foreground="{StaticResource AccentBrush}" />
                <TextBlock
                    Text="DefenderUI"
                    Style="{StaticResource BodyStyle}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- NavigationView with Sidebar -->
        <NavigationView x:ConnectionId='3'
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="True"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            OpenPaneLength="260"
            Background="Transparent"
                                   
                                                       
            AutomationProperties.Name="Main navigation">

            <!-- Navigation Header (Logo area in Pane) -->
            <NavigationView.PaneHeader>
                <StackPanel Padding="12,16" Spacing="2">
                    <TextBlock
                        Text="DefenderUI"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        FontFamily="{StaticResource AppFontFamily}" />
                    <TextBlock
                        Text="Advanced Protection"
                        FontSize="12"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        FontFamily="{StaticResource AppFontFamily}" />
                </StackPanel>
            </NavigationView.PaneHeader>

            <!-- Menu Items -->
            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="Dashboard"
                    Tag="dashboard"
                    IsSelected="True"
                    AutomationProperties.Name="Dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE72E;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Scan"
                    Tag="scan"
                    AutomationProperties.Name="Scan">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE721;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Protection"
                    Tag="protection"
                    AutomationProperties.Name="Protection">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA18;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Quarantine"
                    Tag="quarantine"
                    AutomationProperties.Name="Quarantine">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7BA;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Reports"
                    Tag="reports"
                    AutomationProperties.Name="Reports">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Update"
                    Tag="update"
                    AutomationProperties.Name="Update">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE895;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- Footer Menu Items -->
            <NavigationView.FooterMenuItems>
                <NavigationViewItem
                    Content="Settings"
                    Tag="settings"
                    AutomationProperties.Name="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <!-- Content Frame -->
            <Frame x:ConnectionId='4'
                x:Name="ContentFrame"
                Padding="24"
                Background="Transparent" />
        </NavigationView>
    </Grid>
</Window>

