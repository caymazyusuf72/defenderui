<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="DefenderUI.Controls.SettingsRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        SettingsRow — Settings sayfasında sol metin + sağ kontrol düzeni (Faz 5).
        DP:
          • Title       : ayar başlığı (bold)
          • Description : alt açıklama (caption)
          • Glyph       : opsiyonel Segoe glyph (boş ise gizli)
        ContentPresenter üzerinden sağa herhangi bir kontrol (ToggleSwitch, ComboBox, Button vs.)
        yerleştirilebilir:
            <local:SettingsRow Title="Başlık" Description="Açıklama">
                <ToggleSwitch IsOn="..."/>
            </local:SettingsRow>
    -->

    <Border
        x:Name="RowRoot"
        Background="Transparent"
        Padding="4,8">
        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Sol: opsiyonel ikon -->
            <FontIcon
                x:Name="IconGlyph"
                Grid.Column="0"
                Glyph=""
                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                FontSize="18"
                Foreground="{ThemeResource AccentPrimaryBrush}"
                VerticalAlignment="Center"
                Visibility="Collapsed" />

            <!-- Orta: Title + Description -->
            <StackPanel
                Grid.Column="1"
                Spacing="2"
                VerticalAlignment="Center">
                <TextBlock
                    x:Name="TitleLabel"
                    Text="Başlık"
                    Style="{StaticResource BodyLargeTextStyle}"
                    FontWeight="SemiBold"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="DescriptionLabel"
                    Text=""
                    Style="{StaticResource CaptionTextStyle}"
                    TextWrapping="Wrap"
                    Visibility="Collapsed" />
            </StackPanel>

            <!-- Sağ: Content (ToggleSwitch, ComboBox, Button, vs.) -->
            <ContentPresenter
                x:Name="ContentSlot"
                Grid.Column="2"
                Content="{x:Bind RowContent, Mode=OneWay}"
                VerticalAlignment="Center"
                HorizontalAlignment="Right" />
        </Grid>
    </Border>
</UserControl>