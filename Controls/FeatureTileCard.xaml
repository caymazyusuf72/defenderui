<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="DefenderUI.Controls.FeatureTileCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        FeatureTileCard — Dashboard "Hızlı Eylemler" kartı (Faz 3).
        DP:
          • Glyph         : Segoe glyph (string)
          • Title         : başlık
          • Description   : açıklama
          • ActionText    : alt link metni (default "Aç")
          • Command       : ICommand
          • AccentBrush   : özel accent brush (default AccentPrimaryBrush)
          • BadgeText     : opsiyonel pill rozet (null → gizli)
    -->

    <Button
        x:Name="RootButton"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch"
        Background="Transparent"
        BorderThickness="0"
        Padding="0"
        CornerRadius="{StaticResource CornerRadiusCard}"
        Click="RootButton_Click">
        <Border
            x:Name="CardRoot"
            Style="{StaticResource FeatureTileCardStyle}"
            HorizontalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Üst satır: sol ikon circle + sağda opsiyonel badge -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid
                        Grid.Column="0"
                        Width="40"
                        Height="40">
                        <Ellipse
                            x:Name="IconBackground"
                            Fill="{ThemeResource AccentSoftBrush}"
                            Width="40"
                            Height="40" />
                        <FontIcon
                            x:Name="IconGlyph"
                            Glyph="&#xE72E;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                            FontSize="20"
                            Foreground="{ThemeResource AccentPrimaryBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>

                    <Border
                        x:Name="BadgeBorder"
                        Grid.Column="2"
                        Background="{ThemeResource AccentPrimaryBrush}"
                        CornerRadius="{StaticResource CornerRadiusPill}"
                        Padding="10,3"
                        VerticalAlignment="Top"
                        Visibility="Collapsed">
                        <TextBlock
                            x:Name="BadgeTextLabel"
                            Text=""
                            Style="{StaticResource CaptionTextStyle}"
                            Foreground="{ThemeResource TextOnAccentBrush}"
                            FontWeight="SemiBold" />
                    </Border>
                </Grid>

                <!-- Orta: Title + Description -->
                <StackPanel
                    Grid.Row="1"
                    Margin="0,16,0,0"
                    Spacing="4"
                    VerticalAlignment="Top">
                    <TextBlock
                        x:Name="TitleLabel"
                        Text="Başlık"
                        Style="{StaticResource TitleMediumTextStyle}"
                        TextWrapping="Wrap"
                        TextTrimming="None" />
                    <TextBlock
                        x:Name="DescriptionLabel"
                        Text="Açıklama"
                        Style="{StaticResource CaptionTextStyle}"
                        MaxLines="2"
                        TextWrapping="Wrap"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- Alt: "Aç →" linki -->
                <StackPanel
                    Grid.Row="2"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    Spacing="4"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
                    <TextBlock
                        x:Name="ActionTextLabel"
                        Text="Aç"
                        Style="{StaticResource BodyMediumTextStyle}"
                        Foreground="{ThemeResource AccentPrimaryBrush}"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center" />
                    <FontIcon
                        Glyph="&#xE76C;"
                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                        FontSize="12"
                        Foreground="{ThemeResource AccentPrimaryBrush}"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Button>
</UserControl>