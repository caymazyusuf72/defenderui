<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="DefenderUI.Controls.StatCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        StatCard — Dashboard küçük KPI kartı (Faz 3).
        DP:
          • Glyph         : Segoe glyph
          • Label         : üst küçük metin (uppercase) - örn. "TARANAN DOSYA"
          • Value         : büyük sayı - örn. "12,345"
          • Trend         : opsiyonel trend metni - örn. "+12%"
          • TrendPositive : true → yeşil, false → kırmızı (default true)
    -->

    <Border Style="{StaticResource StatCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Üst: İkon + Label -->
            <StackPanel
                Grid.Row="0"
                Orientation="Horizontal"
                Spacing="8">
                <FontIcon
                    x:Name="IconGlyph"
                    Glyph="&#xE8F1;"
                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                    FontSize="18"
                    Foreground="{ThemeResource AccentPrimaryBrush}"
                    VerticalAlignment="Center" />
                <TextBlock
                    x:Name="LabelText"
                    Text="LABEL"
                    Style="{StaticResource OverlineTextStyle}"
                    VerticalAlignment="Center" />
            </StackPanel>

            <!-- Orta: Değer -->
            <TextBlock
                x:Name="ValueText"
                Grid.Row="1"
                Text="0"
                Style="{StaticResource DisplayLargeTextStyle}"
                Margin="0,8,0,0" />

            <!-- Alt: Trend rozeti -->
            <Border
                x:Name="TrendBadge"
                Grid.Row="2"
                HorizontalAlignment="Left"
                Background="{ThemeResource StatusProtectedSoftBrush}"
                CornerRadius="{StaticResource CornerRadiusPill}"
                Padding="8,2"
                Margin="0,8,0,0"
                Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon
                        x:Name="TrendIcon"
                        Glyph="&#xE74A;"
                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                        FontSize="10"
                        Foreground="{ThemeResource StatusProtectedBrush}"
                        VerticalAlignment="Center" />
                    <TextBlock
                        x:Name="TrendLabel"
                        Text=""
                        Style="{StaticResource CaptionTextStyle}"
                        Foreground="{ThemeResource StatusProtectedBrush}"
                        FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>