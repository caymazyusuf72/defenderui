<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="DefenderUI.Controls.StatusHeroCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        StatusHeroCard — Dashboard ana durum kartı (Faz 3).
        DP:
          • Severity               : Protected / AtRisk / AttentionNeeded (ProtectionState)
          • Title                  : başlık metni
          • SubTitle               : alt metin
          • PrimaryActionText      : birincil CTA
          • SecondaryActionText    : ikincil CTA
          • PrimaryActionCommand   : ICommand
          • SecondaryActionCommand : ICommand
    -->

    <Border
        x:Name="RootCard"
        Style="{StaticResource HeroStatusCardStyle}">
        <Border.Background>
            <LinearGradientBrush x:Name="HeroGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="GradientStop1" Color="#1A107C10" Offset="0.0" />
                <GradientStop x:Name="GradientStop2" Color="#00107C10" Offset="0.55" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Sol: Büyük shield ikonu -->
            <Grid
                Grid.Column="0"
                Width="112"
                Height="112"
                VerticalAlignment="Center">
                <Ellipse
                    x:Name="IconHalo"
                    Fill="{ThemeResource StatusProtectedSoftBrush}"
                    Width="112"
                    Height="112" />
                <FontIcon
                    x:Name="HeroIcon"
                    Glyph="&#xE72E;"
                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                    FontSize="72"
                    Foreground="{ThemeResource StatusProtectedBrush}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
            </Grid>

            <!-- Orta: Title + SubTitle -->
            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Spacing="8">
                <TextBlock
                    x:Name="TitleText"
                    Text="Bilgisayarınız Korunuyor"
                    Style="{StaticResource DisplayMediumTextStyle}"
                    TextWrapping="Wrap"
                    TextTrimming="None" />
                <TextBlock
                    x:Name="SubTitleText"
                    Text="Son tarama: bugün 14:30"
                    Style="{StaticResource BodyLargeTextStyle}"
                    Foreground="{ThemeResource TextSecondaryBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <!-- Sağ: iki dikey buton -->
            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Spacing="12"
                MinWidth="200">
                <Button
                    x:Name="PrimaryButton"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Content="Hızlı Tarama"
                    Click="PrimaryButton_Click" />
                <Button
                    x:Name="SecondaryButton"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Style="{StaticResource SecondaryActionButtonStyle}"
                    Content="Tüm Sistemi Tara"
                    Click="SecondaryButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>