<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows10.0.26100.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>DefenderUI</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>x86;x64;ARM64</Platforms>
    <RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
    <PublishProfile>win-$(Platform).pubxml</PublishProfile>
    <UseWinUI>true</UseWinUI>
    <WinUISDKReferences>false</WinUISDKReferences>
    <EnableMsixTooling>true</EnableMsixTooling>
    <WindowsPackageType>None</WindowsPackageType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!--
      MVVMTK0045: CommunityToolkit.Mvvm AOT-partial-property migration uyarısı.
      Proje WinUI 3 unpackaged + JIT çalışıyor; AOT hedefi yok. Partial property
      migration daha büyük bir refactor gerektirdiği için Faz 7'de global olarak
      bastırıyoruz. Gerektiğinde kaldırılabilir.
    -->
    <NoWarn>$(NoWarn);MVVMTK0045</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="Assets\SplashScreen.scale-200.png" />
    <Content Include="Assets\SplashScreen.png" />
    <Content Include="Assets\LockScreenLogo.scale-200.png" />
    <Content Include="Assets\Square150x150Logo.scale-200.png" />
    <Content Include="Assets\Square150x150Logo.png" />
    <Content Include="Assets\Square44x44Logo.scale-200.png" />
    <Content Include="Assets\Square44x44Logo.png" />
    <Content Include="Assets\Square44x44Logo.targetsize-24_altform-unplated.png" />
    <Content Include="Assets\StoreLogo.png" />
    <Content Include="Assets\AppIcon.ico" />
    <Content Include="Assets\Wide310x150Logo.scale-200.png" />
    <Content Include="Assets\Wide310x150Logo.png" />
    <Content Include="Assets\AppLogo-32.png" />
    <Content Include="Assets\AppLogo-64.png" />
    <Content Include="Assets\AppLogo-128.png" />
    <Content Include="Assets\AppLogo-256.png" />
  </ItemGroup>

  <ItemGroup>
    <Manifest Include="$(ApplicationManifest)" />
  </ItemGroup>


  <!--
    Defining the "Msix" ProjectCapability here allows the Single-project MSIX Packaging
    Tools extension to be activated for this project even if the Windows App SDK Nuget
    package has not yet been restored.
  -->
  <ItemGroup Condition="'$(DisableMsixProjectCapabilityAddedByProject)'!='true' and '$(EnableMsixTooling)'=='true'">
    <ProjectCapability Include="Msix"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="*" />
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="*" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.*" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.*" />
  </ItemGroup>

  <!--
    Defining the "HasPackageAndPublishMenuAddedByProject" property here allows the Solution
    Explorer "Package and Publish" context menu entry to be enabled for this project even if
    the Windows App SDK Nuget package has not yet been restored.
  -->
  <PropertyGroup Condition="'$(DisableHasPackageAndPublishMenuAddedByProject)'!='true' and '$(EnableMsixTooling)'=='true'">
    <HasPackageAndPublishMenu>true</HasPackageAndPublishMenu>
  </PropertyGroup>

  <!-- Publish Properties -->
  <PropertyGroup>
    <PublishReadyToRun Condition="'$(Configuration)' == 'Debug'">False</PublishReadyToRun>
    <PublishReadyToRun Condition="'$(Configuration)' != 'Debug'">True</PublishReadyToRun>
    <!--
      NOTE: PublishTrimmed WinUI 3 (WindowsAppSDK 1.8) ile pek çok "IL trim" uyarisi
      uretir ve XAML tip cozumlemesini bozabilir. Guvenli olmasi icin Release'te de
      kapali tutuyoruz. Single-file publish basarisiz olursa buradan acilabilir.
    -->
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>

  <!--
    Single-file publish konfigurasyonu (sadece Release icin).
    Hedef: `dotnet publish -c Release -r win-x64 -p:Platform=x64 -o publish`
    komutu ile tek bir DefenderUI.exe uretmek.

    - PublishSingleFile=true                        => yonetilen DLL'ler exe icine gomulur
    - SelfContained=true                            => .NET runtime exe icine dahil edilir
    - IncludeNativeLibrariesForSelfExtract=true     => native DLL'ler calisma aninda temp'e acilir
    - IncludeAllContentForSelfExtract=true          => tum icerik dosyalari da gomulur
    - EnableCompressionInSingleFile=true            => exe sikistirilir
    - WindowsAppSDKSelfContained=true               => WinAppSDK runtime bagimliligi kaldirilir
    - WindowsPackageType=None                       => unpackaged desktop app
    - DebugType=embedded                            => PDB exe icine gomulur (yan .pdb yok)

    Onemli: WinUI 3 / WindowsAppSDK 1.8 bazi native bootstrap DLL'lerini hala
    yaninda tasimak zorunda kalabilir; detaylar icin SINGLE_FILE_PUBLISH.md.
  -->
  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <WindowsPackageType>None</WindowsPackageType>
    <DebugType>embedded</DebugType>
    <!-- Single-file ile trim birlikte WinUI'de riskli; acik bicimde kapatiyoruz. -->
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>